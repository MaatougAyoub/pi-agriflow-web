{% extends 'layouts/front.html.twig' %}

{% block page_title %}Candidatures - {{ request.title }}{% endblock %}

{% block front_body %}
<section class="section">
    <div class="container">
        {# Header #}
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1"><i class="bi bi-people me-2 text-primary"></i>Candidatures reçues</h2>
                <p class="text-muted mb-0">Pour la demande : <strong>{{ request.title }}</strong></p>
            </div>
            <a href="{{ path('app_collab_my_requests') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Retour</a>
        </div>

        {# Résumé de la demande #}
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px; background: #f0fdf4;">
            <div class="card-body p-3 d-flex flex-wrap gap-4 align-items-center">
                <span><i class="bi bi-geo-alt text-success me-1"></i>{{ request.location }}</span>
                <span><i class="bi bi-cash text-success me-1"></i>{{ request.salary }} DT/jour</span>
                <span><i class="bi bi-people text-success me-1"></i>{{ request.neededPeople }} personne(s)</span>
                <span><i class="bi bi-calendar text-success me-1"></i>{{ request.startDate|date('d/m/Y') }} → {{ request.endDate|date('d/m/Y') }}</span>
                <span class="ms-auto fw-bold fst-italic text-primary"><i class="bi bi-robot me-1"></i>IA Matching Activée</span>
                <span class="fw-bold">{{ rankedScores|length }} candidature(s)</span>
            </div>
        </div>

        {% if rankedScores|length == 0 %}
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                <h3 class="text-muted mt-3">Aucune candidature reçue</h3>
                <p class="text-muted">Les candidats pourront postuler une fois la demande approuvée.</p>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle bg-white shadow-sm" style="border-radius: 12px; overflow: hidden;">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 25%;">Candidat</th>
                            <th class="text-center" style="width: 25%;">Score Matching IA</th>
                            <th class="text-center">Expérience</th>
                            <th class="text-center">Recommandation</th>
                            <th class="text-center">Statut</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for score in rankedScores %}
                        {% set app = score.application %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="flex-grow-1">
                                        <div class="fw-bold">{{ app.fullName }}</div>
                                        <div class="small text-muted"><i class="bi bi-envelope me-1"></i>{{ app.email }}</div>
                                        <div class="small text-muted"><i class="bi bi-telephone me-1"></i>{{ app.phone }}</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="px-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="small fw-bold">{{ score.scoreEmoji }} {{ score.totalScore|round }}%</span>
                                        <span class="small text-muted">{{ score.starsDisplay }}</span>
                                    </div>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar" role="progressbar" 
                                             style="width: {{ score.totalScore }}%; background-color: {{ score.scoreColor }};" 
                                             aria-valuenow="{{ score.totalScore }}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <div class="mt-2 small d-flex flex-wrap gap-2 text-muted" style="font-size: 0.75rem;">
                                        <span title="Basé sur les années d'expérience">Exp: {{ score.experienceScore|round }}%</span>
                                        <span title="Comparaison salaire demandé vs proposé">Prix: {{ score.salaryScore|round }}%</span>
                                        <span title="Pertinence géographique">Lieu: {{ score.locationScore|round }}%</span>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border px-3 py-2">{{ app.yearsOfExperience }} ans</span>
                                <div class="small fw-bold mt-1">{{ app.expectedSalary }} DT</div>
                            </td>
                            <td class="text-center">
                                <span class="small fw-bold px-2 py-1 rounded" style="background-color: {{ score.scoreColor }}22; color: {{ score.scoreColor }};">
                                    {{ score.recommendation }}
                                </span>
                            </td>
                            <td class="text-center">
                                {% if app.status == 'PENDING' %}
                                    <span class="badge bg-warning text-dark px-2 py-1"><i class="bi bi-hourglass-split me-1"></i>Attente</span>
                                {% elseif app.status == 'APPROVED' %}
                                    <span class="badge bg-success px-2 py-1"><i class="bi bi-check-circle me-1"></i>Acceptée</span>
                                {% elseif app.status == 'REJECTED' %}
                                    <span class="badge bg-danger px-2 py-1"><i class="bi bi-x-circle me-1"></i>Refusée</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if app.status == 'PENDING' %}
                                    <div class="d-flex flex-column gap-1">
                                        <form method="post" action="{{ path('app_collab_update_app_status', {id: app.id, action: 'approve'}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ app.id) }}">
                                            <button type="submit" class="btn btn-success btn-sm w-100" 
                                                    onclick="return confirm('Accepter {{ app.fullName }} ?');">
                                                Accepter
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('app_collab_update_app_status', {id: app.id, action: 'reject'}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ app.id) }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                                    onclick="return confirm('Refuser {{ app.fullName }} ?');">
                                                Refuser
                                            </button>
                                        </form>
                                    </div>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                        <tr class="table-sm">
                            <td colspan="6" class="p-0 border-0">
                                <div class="px-4 py-3 bg-light border-top border-bottom">
                                    <div class="row align-items-center">
                                        <div class="col-lg-6">
                                            <div class="p-3 rounded-2 bg-white shadow-sm h-100">
                                                <h6 class="fw-bold mb-2 small text-muted text-uppercase"><i class="bi bi-chat-left-quote me-2"></i>Motivation du candidat :</h6>
                                                <p class="mb-0 small fst-italic">"{{ app.motivation }}"</p>
                                            </div>
                                        </div>
                                        <div class="col-lg-6">
                                            {% if aiAnalyses[app.id] is defined %}
                                                <div class="p-3 rounded-2 shadow-sm h-100" style="background: #e0f2fe; border-left: 4px solid #0284c7;">
                                                    <h6 class="fw-bold mb-2 small text-info text-uppercase"><i class="bi bi-robot me-2"></i>Analyse de Fit IA :</h6>
                                                    <p class="mb-0 small text-dark">{{ aiAnalyses[app.id] }}</p>
                                                </div>
                                            {% else %}
                                                <div class="p-3 rounded-2 bg-white shadow-sm h-100 d-flex align-items-center justify-content-center">
                                                    <span class="text-muted small italic">IA Analyse non disponible</span>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
