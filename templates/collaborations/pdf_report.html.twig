<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Rapport de Collaboration AgriFlow</title>
    <style>
        body { font-family: 'Helvetica', 'Arial', sans-serif; color: #333; line-height: 1.5; }
        .header { text-align: center; border-bottom: 2px solid #2e7d32; padding-bottom: 20px; margin-bottom: 30px; }
        .logo { color: #2e7d32; font-size: 28px; font-weight: bold; }
        .title { font-size: 22px; color: #1b5e20; margin-top: 10px; }
        .section { margin-bottom: 20px; }
        .section-title { font-weight: bold; border-left: 4px solid #2e7d32; padding-left: 10px; color: #2e7d32; margin-bottom: 10px; }
        .details-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .details-table td { padding: 8px; border-bottom: 1px solid #eee; }
        .label { font-weight: bold; width: 40%; }
        .value { width: 60%; }
        .footer { position: fixed; bottom: 0; width: 100%; text-align: center; font-size: 10px; color: #666; border-top: 1px solid #ddd; padding-top: 10px; }
        .badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; }
        .badge-success { background-color: #c8e6c9; color: #2e7d32; }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">AgriFlow</div>
        <div class="title">Rapport Officiel de Demande de Collaboration</div>
    </div>

    <div class="section">
        <div class="section-title">Informations Générales</div>
        <table class="details-table">
            <tr>
                <td class="label">ID de la demande</td>
                <td class="value">#{{ request.id }}</td>
            </tr>
            <tr>
                <td class="label">Titre</td>
                <td class="value">{{ request.title }}</td>
            </tr>
            <tr>
                <td class="label">Publié par</td>
                <td class="value">{{ request.publisher }}</td>
            </tr>
            <tr>
                <td class="label">Date de création</td>
                <td class="value">{{ request.createdAt|date('d/m/Y H:i') }}</td>
            </tr>
            <tr>
                <td class="label">Statut actuel</td>
                <td class="value">
                    <span class="badge badge-success">{{ request.status }}</span>
                </td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Détails de la Collaboration</div>
        <table class="details-table">
            <tr>
                <td class="label">Localisation</td>
                <td class="value">{{ request.location }}</td>
            </tr>
            <tr>
                <td class="label">Période</td>
                <td class="value">{{ request.startDate|date('d/m/Y') }} au {{ request.endDate|date('d/m/Y') }}</td>
            </tr>
            <tr>
                <td class="label">Salaire proposé</td>
                <td class="value">{{ request.salary }} DT / jour</td>
            </tr>
            <tr>
                <td class="label">Nombre d'ouvriers requis</td>
                <td class="value">{{ request.neededPeople }} personne(s)</td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Description du travail</div>
        <p style="text-align: justify; padding: 0 10px;">{{ request.description }}</p>
    </div>

    <div class="footer">
        Document généré automatiquement par AgriFlow le {{ exportDate|date('d/m/Y à H:i') }}.<br>
        © AgriFlow - Plateforme de Gestion Agricole Moderne.
    </div>
</body>
</html>
