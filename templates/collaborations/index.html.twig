{% extends 'layouts/front.html.twig' %}

{% block page_title %}Collaborations - AgriFlow{% endblock %}

{% block front_hero %}
<style>
    /* ── Search Bar ── */
    .agf-search-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,.06);
        margin-top: -36px;
        position: relative;
        z-index: 10;
        background: #fff;
    }
    .agf-search-card .form-control,
    .agf-search-card .form-select {
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 10px 14px;
        font-size: .9rem;
        transition: border-color .2s, box-shadow .2s;
    }
    .agf-search-card .form-control:focus,
    .agf-search-card .form-select:focus {
        border-color: #16a34a;
        box-shadow: 0 0 0 3px rgba(22,163,74,.1);
    }
    .agf-search-card .form-label {
        font-weight: 600;
        font-size: .8rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .3px;
    }
    .agf-filter-btn {
        background: linear-gradient(135deg, #16a34a, #059669);
        border: none;
        color: #fff;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        transition: all .2s;
        box-shadow: 0 3px 10px rgba(22,163,74,.25);
    }
    .agf-filter-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 5px 16px rgba(22,163,74,.35);
        color: #fff;
    }

    /* ── Quick Links ── */
    .agf-quick-link {
        border: 1.5px solid #e2e8f0;
        background: #fff;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        font-size: .88rem;
        color: #334155;
        transition: all .2s;
        text-decoration: none;
    }
    .agf-quick-link:hover {
        border-color: #16a34a;
        color: #16a34a;
        background: #f0fdf4;
    }
    .agf-quick-link i { margin-right: 6px; }

    /* ── Cards ── */
    .agf-collab-card {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        transition: transform .25s ease, box-shadow .25s ease;
        background: #fff;
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .agf-collab-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 28px rgba(0,0,0,.1);
    }
    .agf-collab-card .card-body {
        padding: 22px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    /* Card top accent */
    .agf-card-accent {
        height: 4px;
        width: 100%;
    }
    .agf-card-accent.approved { background: linear-gradient(90deg, #16a34a, #22c55e); }
    .agf-card-accent.pending { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .agf-card-accent.rejected { background: linear-gradient(90deg, #ef4444, #f87171); }

    .agf-collab-card .card-title {
        font-weight: 700;
        font-size: 1.05rem;
        color: #1e293b;
        line-height: 1.35;
        margin-bottom: 8px;
    }
    .agf-collab-card .card-desc {
        color: #64748b;
        font-size: .87rem;
        line-height: 1.5;
        flex-grow: 1;
    }

    /* Tags */
    .agf-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 12px;
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 600;
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }
    .agf-tag i { font-size: .75rem; }
    .agf-tag.salary {
        background: #ecfdf5;
        color: #166534;
        border-color: #bbf7d0;
    }

    /* Date row */
    .agf-dates {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .82rem;
        color: #64748b;
        padding: 8px 0;
    }
    .agf-dates .arrow {
        color: #cbd5e1;
        font-weight: 700;
    }

    /* Status badge */
    .agf-status {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .3px;
    }
    .agf-status.approved { background: #dcfce7; color: #166534; }
    .agf-status.pending { background: #fef3c7; color: #92400e; }
    .agf-status.rejected { background: #fee2e2; color: #991b1b; }

    /* CTA button */
    .agf-card-cta {
        background: linear-gradient(135deg, #16a34a, #059669);
        color: #fff;
        border: none;
        padding: 10px 0;
        border-radius: 10px;
        font-weight: 600;
        font-size: .9rem;
        width: 100%;
        text-align: center;
        text-decoration: none;
        display: block;
        transition: all .2s;
    }
    .agf-card-cta:hover {
        box-shadow: 0 4px 14px rgba(22,163,74,.3);
        color: #fff;
    }

    /* Publisher line */
    .agf-publisher {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: .82rem;
        color: #94a3b8;
    }
    .agf-publisher-avatar {
        width: 22px; height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #16a34a, #0d9488);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .65rem;
        font-weight: 700;
    }

    /* Empty state */
    .agf-empty-state {
        text-align: center;
        padding: 60px 20px;
    }
    .agf-empty-icon {
        width: 80px; height: 80px;
        border-radius: 50%;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 2rem;
        color: #94a3b8;
    }

    /* Pagination */
    .agf-pagination .page-link {
        border-radius: 8px;
        margin: 0 3px;
        border: 1.5px solid #e2e8f0;
        color: #334155;
        font-weight: 600;
        font-size: .88rem;
        padding: 8px 14px;
        transition: all .2s;
    }
    .agf-pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #16a34a, #059669);
        border-color: transparent;
        color: #fff;
    }
    .agf-pagination .page-link:hover {
        background: #f0fdf4;
        border-color: #16a34a;
        color: #16a34a;
    }

    /* Results count */
    .agf-results-count {
        background: #f8fafc;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: .88rem;
        color: #64748b;
        display: inline-block;
    }
</style>

<section class="hero section dark-background agf-hero" style="min-height: 260px;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="agf-eyebrow">Collaborations agricoles</span>
                <h1 class="display-5 text-white mb-3">Trouvez des opportunités de travail agricole</h1>
                <p class="text-white-50 mb-0">Explorez les demandes de collaboration publiées par les agriculteurs de la communauté.</p>
            </div>
            <div class="col-lg-5 text-end">
                {% if app.user %}
                    <a href="{{ path('app_collab_new') }}" class="btn btn-success btn-lg"><i class="bi bi-plus-circle me-2"></i>Publier une demande</a>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block front_body %}
<section class="section pb-5">
    <div class="container">

        {# ── Search & Filters ── #}
        <div class="row mb-4">
            <div class="col-12 col-xl-10 mx-auto">
                <form method="get" action="{{ path('app_collab_index') }}" class="agf-search-card p-4">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-12 col-lg-4">
                            <label class="form-label mb-1"><i class="bi bi-search me-1"></i>Recherche</label>
                            <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Titre, description, lieu...">
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <label class="form-label mb-1"><i class="bi bi-geo-alt me-1"></i>Lieu</label>
                            <input type="text" name="location" value="{{ filter_location }}" class="form-control" placeholder="Ex: Sfax, Bizerte...">
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <label class="form-label mb-1"><i class="bi bi-sort-down me-1"></i>Tri</label>
                            <select name="sort" class="form-select">
                                <option value="date_desc" {{ list_sort == 'date_desc' ? 'selected' }}>Plus récentes</option>
                                <option value="date_asc" {{ list_sort == 'date_asc' ? 'selected' }}>Plus anciennes</option>
                                <option value="salary_desc" {{ list_sort == 'salary_desc' ? 'selected' }}>Salaire ↓</option>
                                <option value="salary_asc" {{ list_sort == 'salary_asc' ? 'selected' }}>Salaire ↑</option>
                                <option value="title_asc" {{ list_sort == 'title_asc' ? 'selected' }}>Titre (A→Z)</option>
                            </select>
                        </div>
                        <div class="col-lg-2">
                            <button type="submit" class="agf-filter-btn w-100"><i class="bi bi-funnel me-1"></i>Filtrer</button>
                        </div>
                    </div>
                    {% if search or filter_location %}
                        <div class="mt-3 text-center">
                            <a href="{{ path('app_collab_index', {sort: list_sort}) }}" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                <i class="bi bi-x-circle me-1"></i>Réinitialiser les filtres
                            </a>
                        </div>
                    {% endif %}
                </form>
            </div>
        </div>

        {# ── Results Count ── #}
        {% if search or filter_location %}
            <div class="text-center mb-4">
                <span class="agf-results-count">
                    <i class="bi bi-list-ul me-1"></i>
                    <strong>{{ pagination.totalItemCount }}</strong> résultat(s)
                    {% if search %} pour « <strong>{{ search }}</strong> »{% endif %}
                    {% if filter_location %} — lieu : « <strong>{{ filter_location }}</strong> »{% endif %}
                </span>
            </div>
        {% endif %}

        {# ── Quick Links ── #}
        {% if app.user %}
        <div class="d-flex justify-content-center gap-3 mb-4 flex-wrap">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_collab_index') }}" class="agf-quick-link">
                    <i class="bi bi-shield-check"></i>Administration
                </a>
            {% else %}
                <a href="{{ path('app_collab_my_requests') }}" class="agf-quick-link">
                    <i class="bi bi-list-check"></i>Mes demandes
                </a>
                <a href="{{ path('app_collab_my_applications') }}" class="agf-quick-link">
                    <i class="bi bi-send-check"></i>Mes candidatures
                </a>
            {% endif %}
        </div>
        {% endif %}

        {# ── Cards Grid ── #}
        {% if pagination.totalItemCount == 0 %}
            <div class="agf-empty-state">
                <div class="agf-empty-icon">
                    <i class="bi bi-inbox"></i>
                </div>
                <h3 style="font-weight: 700; color: #334155;">Aucune demande disponible</h3>
                <p class="text-muted mb-4">Soyez le premier à publier une demande de collaboration !</p>
                {% if app.user %}
                    <a href="{{ path('app_collab_new') }}" class="btn btn-success btn-lg">
                        <i class="bi bi-plus-circle me-2"></i>Publier une demande
                    </a>
                {% endif %}
            </div>
        {% else %}
            <div class="row g-4">
                {% for req in pagination %}
                <div class="col-lg-4 col-md-6">
                    <div class="agf-collab-card">
                        {# Color accent bar #}
                        <div class="agf-card-accent {{ req.status == 'APPROVED' ? 'approved' : (req.status == 'PENDING' ? 'pending' : 'rejected') }}"></div>

                        <div class="card-body">
                            {# Status + Date row #}
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="agf-status {{ req.status == 'APPROVED' ? 'approved' : (req.status == 'PENDING' ? 'pending' : 'rejected') }}">
                                    {% if req.status == 'APPROVED' %}
                                        <i class="bi bi-check-circle me-1"></i>Approuvée
                                    {% elseif req.status == 'PENDING' %}
                                        <i class="bi bi-hourglass-split me-1"></i>En attente
                                    {% else %}
                                        <i class="bi bi-x-circle me-1"></i>Refusée
                                    {% endif %}
                                </span>
                                <small class="text-muted" style="font-size: .78rem;">
                                    <i class="bi bi-calendar3 me-1"></i>{{ req.createdAt|date('d/m/Y') }}
                                </small>
                            </div>

                            {# Title #}
                            <h5 class="card-title">{{ req.title }}</h5>

                            {# Description #}
                            <p class="card-desc">
                                {{ req.description|length > 110 ? req.description|slice(0, 110) ~ '...' : req.description }}
                            </p>

                            {# Tags #}
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="agf-tag"><i class="bi bi-geo-alt-fill"></i>{{ req.location }}</span>
                                <span class="agf-tag"><i class="bi bi-people-fill"></i>{{ req.neededPeople }} pers.</span>
                                <span class="agf-tag salary"><i class="bi bi-cash-stack"></i>{{ req.salary }} DT/j</span>
                            </div>

                            {# Dates #}
                            <div class="agf-dates">
                                <i class="bi bi-calendar-event text-success"></i>
                                {{ req.startDate|date('d/m/Y') }}
                                <span class="arrow">→</span>
                                {{ req.endDate|date('d/m/Y') }}
                            </div>

                            {# Publisher #}
                            {% if req.publisher %}
                            <div class="agf-publisher mb-3">
                                <div class="agf-publisher-avatar">
                                    {{ req.publisher|first|upper }}
                                </div>
                                {{ req.publisher }}
                            </div>
                            {% endif %}

                            {# CTA #}
                            <div class="mt-auto pt-2">
                                <a href="{{ path('app_collab_show', {id: req.id}) }}" class="agf-card-cta">
                                    <i class="bi bi-eye me-1"></i>Voir les détails
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>

            {# ── Pagination ── #}
            <div class="d-flex justify-content-center mt-5 agf-pagination">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
