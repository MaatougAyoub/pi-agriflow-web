{% extends 'layouts/front.html.twig' %}

{% block page_title %}Collaborations - AgriFlow{% endblock %}

{% block front_hero %}
    <section class="hero section dark-background agf-hero" style="min-height: 260px;">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <span class="agf-eyebrow">Collaborations agricoles</span>
                    <h1 class="display-5 text-white mb-3">Trouvez des opportunités de travail agricole</h1>
                    <p class="text-white-50 mb-0">Explorez les demandes de collaboration publiées par les agriculteurs de la communauté.</p>
                </div>
                <div class="col-lg-5 text-end">
                    {% if app.user %}
                        <a href="{{ path('app_collab_new') }}" class="btn btn-success btn-lg"><i class="bi bi-plus-circle me-2"></i>Publier une demande</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block front_body %}
<section class="section">
    <div class="container">

        {# Recherche, filtre lieu et tri #}
        <div class="row mb-4">
            <div class="col-12 col-xl-10 mx-auto">
                <form method="get" action="{{ path('app_collab_index') }}" class="card border-0 shadow-sm p-3 p-md-4">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-12 col-lg-4">
                            <label class="form-label small text-muted mb-1">Recherche</label>
                            <input type="text" name="q" value="{{ search }}" class="form-control" placeholder="Titre, description, lieu...">
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <label class="form-label small text-muted mb-1">Lieu (contient)</label>
                            <input type="text" name="location" value="{{ filter_location }}" class="form-control" placeholder="Ex. Sfax, Bizerte...">
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <label class="form-label small text-muted mb-1">Tri</label>
                            <select name="sort" class="form-select">
                                <option value="date_desc" {{ list_sort == 'date_desc' ? 'selected' }}>Plus récentes</option>
                                <option value="date_asc" {{ list_sort == 'date_asc' ? 'selected' }}>Plus anciennes</option>
                                <option value="salary_desc" {{ list_sort == 'salary_desc' ? 'selected' }}>Salaire décroissant</option>
                                <option value="salary_asc" {{ list_sort == 'salary_asc' ? 'selected' }}>Salaire croissant</option>
                                <option value="title_asc" {{ list_sort == 'title_asc' ? 'selected' }}>Titre (A → Z)</option>
                            </select>
                        </div>
                        <div class="col-lg-2 d-flex gap-2">
                            <button type="submit" class="btn btn-success flex-grow-1"><i class="bi bi-funnel me-1"></i>Appliquer</button>
                        </div>
                    </div>
                    {% if search or filter_location %}
                        <div class="mt-3 text-center">
                            <a href="{{ path('app_collab_index', {sort: list_sort}) }}" class="btn btn-sm btn-outline-secondary">Réinitialiser recherche / lieu</a>
                        </div>
                    {% endif %}
                </form>
            </div>
        </div>

        {% if search or filter_location %}
            <p class="text-muted text-center mb-4">
                {{ pagination.totalItemCount }} résultat(s)
                {% if search %} pour « <strong>{{ search }}</strong> »{% endif %}
                {% if filter_location %} — lieu contenant « <strong>{{ filter_location }}</strong> »{% endif %}
            </p>
        {% endif %}

        {# Liens rapides selon le rôle #}
        {% if app.user %}
        <div class="d-flex justify-content-center gap-3 mb-4 flex-wrap">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_collab_index') }}" class="btn btn-outline-dark"><i class="bi bi-shield-check me-1"></i>Liste des demandes (Admin)</a>
            {% else %}
                <a href="{{ path('app_collab_my_requests') }}" class="btn btn-outline-success"><i class="bi bi-list-check me-1"></i>Mes demandes</a>
                <a href="{{ path('app_collab_my_applications') }}" class="btn btn-outline-primary"><i class="bi bi-send-check me-1"></i>Mes candidatures</a>
            {% endif %}
        </div>
        {% endif %}

        {# Grille des demandes #}
        {% if pagination.totalItemCount == 0 %}
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                <h3 class="text-muted mt-3">Aucune demande de collaboration disponible</h3>
                <p class="text-muted">Soyez le premier à publier une demande !</p>
                {% if app.user %}
                    <a href="{{ path('app_collab_new') }}" class="btn btn-success mt-2">Publier une demande</a>
                {% endif %}
            </div>
        {% else %}
            <div class="row g-4">
                {% for req in pagination %}
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 shadow-sm border-0" style="border-radius: 16px; overflow: hidden; transition: transform .2s;">
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-{{ req.status == 'APPROVED' ? 'success' : (req.status == 'PENDING' ? 'warning text-dark' : 'danger') }}">
                                    {{ req.status == 'APPROVED' ? 'Approuvée' : (req.status == 'PENDING' ? 'En attente' : 'Refusée') }}
                                </span>
                                <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>{{ req.createdAt|date('d/m/Y') }}</small>
                            </div>

                            <h5 class="card-title fw-bold mb-2">{{ req.title }}</h5>
                            <p class="card-text text-muted mb-3" style="font-size: 0.9rem;">
                                {{ req.description|length > 120 ? req.description|slice(0, 120) ~ '...' : req.description }}
                            </p>

                            <div class="mb-3">
                                <div class="d-flex flex-wrap gap-2">
                                    <span class="badge bg-light text-dark border"><i class="bi bi-geo-alt me-1"></i>{{ req.location }}</span>
                                    <span class="badge bg-light text-dark border"><i class="bi bi-people me-1"></i>{{ req.neededPeople }} pers.</span>
                                    <span class="badge bg-light text-dark border"><i class="bi bi-cash me-1"></i>{{ req.salary }} DT/jour</span>
                                </div>
                            </div>

                            <div class="d-flex gap-2 mb-2" style="font-size: 0.85rem;">
                                <span class="text-success"><i class="bi bi-calendar-check me-1"></i>{{ req.startDate|date('d/m/Y') }}</span>
                                <span class="text-muted">→</span>
                                <span class="text-danger"><i class="bi bi-calendar-x me-1"></i>{{ req.endDate|date('d/m/Y') }}</span>
                            </div>

                            {% if req.publisher %}
                                <small class="text-muted mb-3"><i class="bi bi-person me-1"></i>{{ req.publisher }}</small>
                            {% endif %}

                            <div class="mt-auto pt-3">
                                <a href="{{ path('app_collab_show', {id: req.id}) }}" class="btn btn-outline-success w-100">
                                    <i class="bi bi-eye me-1"></i>Voir les détails
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>

            <div class="d-flex justify-content-center mt-5 pagination-container">
                {{ knp_pagination_render(pagination) }}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
