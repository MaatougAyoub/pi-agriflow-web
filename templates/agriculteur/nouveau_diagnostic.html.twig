{% extends 'layouts/front.html.twig' %}

{% block page_title %}Nouveau Diagnostic{% endblock %}

{% block front_body %}
<section style="padding:40px 0;background:#F0F2F5;min-height:80vh">
<div class="container">
    <div class="card shadow-sm border-0 rounded-4 p-4" style="max-width:700px;margin:0 auto">
        <h3 style="color:#2D5A27;font-weight:700">📝 Nouveau diagnostic</h3>
        <form method="post" enctype="multipart/form-data" class="mt-4">
            <div class="mb-3">
                <label class="form-label fw-bold">Culture concernée</label>
                <input type="text" name="nomCulture" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Description des symptômes</label>
                <textarea name="description" class="form-control" rows="5" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Photo (optionnelle)</label>
                <input type="file" name="image" class="form-control" accept="image/*">
                <small class="text-muted">Formats acceptés : JPG, PNG, GIF (max 5 Mo)</small>
            </div>
            <div class="d-flex gap-2 mt-4 justify-content-end">
                <a href="{{ path('agriculteur_diagnostics') }}" class="btn btn-outline-secondary" style="border-radius:20px">Annuler</a>
                <button type="submit" class="btn" style="background:#2D5A27;color:white;border-radius:20px">📤 Envoyer</button>
            </div>
        </form>
    </div>
</div>
</section>
{% endblock %}