{% extends 'layouts/front.html.twig' %}
{% block page_title %}Détail Plan d irrigation{% endblock %}
{% block front_body %}
<section style="padding:40px 0;background:#F0F2F5;min-height:80vh">
<div class="container">

    <a href="{{ path('agriculteur_irrigation') }}"
       style="display:inline-block;margin-bottom:25px;padding:8px 20px;border-radius:20px;
              border:1.5px solid #ccc;color:#666;text-decoration:none;font-weight:600">
        ← Retour
    </a>

    <div style="background:linear-gradient(135deg,#1B4332,#2D6A4F);border-radius:14px;
                padding:30px 35px;color:white;margin-bottom:30px">
        <div style="font-size:13px;opacity:0.8;margin-bottom:6px;text-transform:uppercase;letter-spacing:1px">
            Mon plan d irrigation
        </div>
        <div style="font-size:24px;font-weight:800;margin-bottom:8px">{{ plan.nomCulture }}</div>
        <div style="opacity:0.85;font-size:14px">
            Volume : {{ plan.volumeEauPropose }} L |
            Date : {{ plan.dateDemande ? plan.dateDemande|date('d/m/Y') : '-' }} |
            <span style="background:rgba(255,255,255,0.2);padding:3px 10px;border-radius:20px">
                {{ plan.statut|default('en_attente')|replace({'_': ' '}) }}
            </span>
        </div>
    </div>

    <div style="background:white;border-radius:14px;padding:30px;box-shadow:0 2px 12px rgba(0,0,0,0.07)">
        <h3 style="color:#1B4332;margin-bottom:20px;font-size:17px">📅 Planning Hebdomadaire</h3>

        {% set joursKeys = ['LUN','MAR','MER','JEU','VEN','SAM','DIM'] %}
        {% set joursLabels = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'] %}

        {% set hasData = false %}
        {% for k in joursKeys %}
            {% if jourData[k] is defined %}{% set hasData = true %}{% endif %}
        {% endfor %}

        {% if not hasData %}
        <div style="text-align:center;color:#95a5a6;padding:40px">
            <div style="font-size:40px;margin-bottom:10px">⏳</div>
            <p>L expert n a pas encore rempli ce plan.</p>
        </div>
        {% else %}
        <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse">
            <thead>
                <tr style="background:#f8f9fa">
                    <th style="padding:12px;text-align:left;color:#1B4332;font-size:13px">Données</th>
                    {% for j in joursLabels %}
                    <th style="padding:12px;text-align:center;color:#1B4332;font-weight:700">{{ j }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                <tr style="border-bottom:1px solid #f0f0f0">
                    <td style="padding:12px;font-weight:700;color:#1B4332;font-size:13px">💧 Eau (mm)</td>
                    {% for k in joursKeys %}
                    <td style="padding:12px;text-align:center;font-weight:600">
                        {{ jourData[k] is defined ? jourData[k].eauMm : '-' }}
                    </td>
                    {% endfor %}
                </tr>
                <tr style="border-bottom:1px solid #f0f0f0">
                    <td style="padding:12px;font-weight:700;color:#1B4332;font-size:13px">⏱ Durée (min)</td>
                    {% for k in joursKeys %}
                    <td style="padding:12px;text-align:center;font-weight:600">
                        {{ jourData[k] is defined ? jourData[k].tempsMin : '-' }}
                    </td>
                    {% endfor %}
                </tr>
                <tr style="border-bottom:1px solid #f0f0f0">
                    <td style="padding:12px;font-weight:700;color:#1B4332;font-size:13px">🌡 Temp (°C)</td>
                    {% for k in joursKeys %}
                    <td style="padding:12px;text-align:center;font-weight:600">
                        {{ jourData[k] is defined ? jourData[k].tempC : '-' }}
                    </td>
                    {% endfor %}
                </tr>
                <tr style="border-bottom:1px solid #f0f0f0">
                    <td style="padding:12px;font-weight:700;color:#1B4332;font-size:13px">💦 Humidité (%)</td>
                    {% for k in joursKeys %}
                    <td style="padding:12px;text-align:center;font-weight:600">
                        {{ jourData[k] is defined ? jourData[k].humidite : '-' }}
                    </td>
                    {% endfor %}
                </tr>
                <tr>
                    <td style="padding:12px;font-weight:700;color:#1B4332;font-size:13px">🌧 Pluie (mm)</td>
                    {% for k in joursKeys %}
                    <td style="padding:12px;text-align:center;font-weight:600">
                        {{ jourData[k] is defined ? jourData[k].pluie : '-' }}
                    </td>
                    {% endfor %}
                </tr>
            </tbody>
        </table>
        </div>
        {% endif %}
    </div>

</div>
</section>
{% endblock %}
