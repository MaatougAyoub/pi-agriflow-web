<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>Devis reservation {{ reservation.id }}</title>
        <style>
            body { font-family: DejaVu Sans, sans-serif; color: #18392b; font-size: 13px; margin: 32px; }
            .header { display: table; width: 100%; margin-bottom: 24px; }
            .header > div { display: table-cell; vertical-align: middle; }
            .logo { width: 160px; }
            .logo img { max-width: 140px; }
            .title { text-align: right; }
            .title h1 { margin: 0; font-size: 24px; }
            .title p { margin: 6px 0 0; color: #5b6b5d; }
            .panel { border: 1px solid #d7e3d8; border-radius: 12px; padding: 16px; margin-bottom: 18px; }
            .panel h2 { margin: 0 0 12px; font-size: 16px; }
            .grid { width: 100%; border-collapse: collapse; }
            .grid td { padding: 8px 0; vertical-align: top; }
            .grid td:first-child { width: 34%; color: #627264; font-weight: bold; }
            .amounts { width: 100%; border-collapse: collapse; margin-top: 16px; }
            .amounts td { padding: 10px 12px; border-bottom: 1px solid #e2ebe3; }
            .amounts tr:last-child td { font-weight: bold; font-size: 15px; border-bottom: none; }
            .diagnostic-score { display: inline-block; padding: 8px 12px; border-radius: 999px; background: #18392b; color: #fff; font-weight: bold; }
            .pill { display: inline-block; margin: 0 6px 6px 0; padding: 6px 10px; border-radius: 999px; font-size: 11px; font-weight: bold; }
            .pill-success { background: #e8f6ed; color: #1d5f3a; }
            .pill-warning { background: #fff4dd; color: #8a6110; }
            .advice { margin: 10px 0 0; padding-left: 18px; color: #496046; }
            .footer-note { margin-top: 24px; font-size: 12px; color: #5b6b5d; }
        </style>
    </head>
    <body>
        <div class="header">
            <div class="logo">
                <img src="{{ logoPath }}" alt="AgriFlow">
            </div>
            <div class="title">
                <h1>Devis de reservation</h1>
                <p>Reference #{{ reservation.id }} - genere le {{ generatedAt|date('d/m/Y H:i') }}</p>
            </div>
        </div>

        <div class="panel">
            <h2>Annonce concernee</h2>
            <table class="grid">
                <tr><td>Titre</td><td>{{ annonce.titre }}</td></tr>
                <tr><td>Type</td><td>{{ annonce.type.label() }}</td></tr>
                <tr><td>Categorie</td><td>{{ annonce.categorie }}</td></tr>
                <tr><td>Localisation</td><td>{{ annonce.localisationNormalisee ?: annonce.localisation }}</td></tr>
                <tr><td>Tarif</td><td>{{ annonce.prix }} TND / {{ annonce.unitePrix }}</td></tr>
            </table>
        </div>

        <div class="panel">
            <h2>Parties</h2>
            <table class="grid">
                <tr>
                    <td>Client</td>
                    <td>
                        {% if client %}
                            {{ client.nom }} {{ client.prenom }}<br>
                            {{ client.email }}
                        {% else %}
                            Client #{{ reservation.clientId }}
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td>Vendeur</td>
                    <td>
                        {% if vendeur %}
                            {{ vendeur.nom }} {{ vendeur.prenom }}<br>
                            {{ vendeur.email }}
                        {% else %}
                            Vendeur #{{ reservation.proprietaireId }}
                        {% endif %}
                    </td>
                </tr>
                <tr><td>Statut</td><td>{{ reservation.statut.label() }}</td></tr>
            </table>
        </div>

        <div class="panel">
            <h2>Detail de la demande</h2>
            <table class="grid">
                {% if annonce.isLocation() %}
                    <tr><td>Periode</td><td>{{ reservation.dateDebut|date('d/m/Y') }} au {{ reservation.dateFin|date('d/m/Y') }}</td></tr>
                    <tr><td>Duree calculee</td><td>{{ reservation.nombreJours }} jour(s)</td></tr>
                {% else %}
                    <tr><td>Periode</td><td>Vente ponctuelle</td></tr>
                {% endif %}
                <tr><td>Quantite</td><td>{{ reservation.quantite }}</td></tr>
                <tr><td>Message</td><td>{{ reservation.message ?: 'Aucune note complementaire.' }}</td></tr>
            </table>

            <table class="amounts">
                <tr>
                    <td>Sous-total</td>
                    <td>{{ (reservation.prixTotalAsFloat - reservation.commissionAsFloat)|number_format(2, '.', ' ') }} TND</td>
                </tr>
                <tr>
                    <td>Commission plateforme</td>
                    <td>{{ reservation.commission }} TND</td>
                </tr>
                <tr>
                    <td>Total TTC</td>
                    <td>{{ reservation.prixTotal }} TND</td>
                </tr>
            </table>
        </div>

        {% if businessDiagnostic %}
            <div class="panel">
                <h2>Analyse Marketplace</h2>
                <table class="grid">
                    <tr>
                        <td>Score metier</td>
                        <td><span class="diagnostic-score">{{ businessDiagnostic.score }}/100 - {{ businessDiagnostic.level }}</span></td>
                    </tr>
                    <tr>
                        <td>Commission</td>
                        <td>Commission plateforme appliquee: {{ businessDiagnostic.commissionRateLabel }}</td>
                    </tr>
                    <tr>
                        <td>APIs externes</td>
                        <td>
                            Meteo: {{ businessDiagnostic.weatherAvailable ? 'disponible' : 'indisponible' }} -
                            Qualite de l air: {{ businessDiagnostic.airQualityAvailable ? 'disponible' : 'indisponible' }}
                        </td>
                    </tr>
                </table>

                <div>
                    {% for badge in businessDiagnostic.badges %}
                        <span class="pill pill-{{ badge.state }}">{{ badge.label }}</span>
                    {% endfor %}
                </div>

                {% if businessDiagnostic.advice is not empty %}
                    <ul class="advice">
                        {% for advice in businessDiagnostic.advice %}
                            <li>{{ advice }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        {% endif %}

        <p class="footer-note">
            Ce devis est genere automatiquement depuis le module Marketplace AgriFlow pour consultation, suivi vendeur et supervision administrateur.
        </p>
    </body>
</html>
