{% extends 'base.html.twig' %}

{% block title %}Détails de la demande{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3>Détails de la demande</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h4>{{ request.title }}</h4>
                            <p class="text-muted">{{ request.description }}</p>
                            
                            <div class="row mt-4">
                                <div class="col-md-6">
                                    <strong>Localisation:</strong> {{ request.location }}<br>
                                    <strong>Date début:</strong> {{ request.startDate ? request.startDate|date('d/m/Y') : 'Non spécifiée' }}<br>
                                    <strong>Date fin:</strong> {{ request.endDate ? request.endDate|date('d/m/Y') : 'Non spécifiée' }}<br>
                                    <strong>Personnes requises:</strong> {{ request.neededPeople }}
                                </div>
                                <div class="col-md-6">
                                    <strong>Salaire par jour:</strong> {{ request.salaryPerDay|number_format(2, ',', ' ') }} DT<br>
                                    <strong>Statut:</strong> 
                                    {% if request.status == 'PENDING' %}
                                        <span class="badge bg-warning">En attente</span>
                                    {% elseif request.status == 'APPROVED' %}
                                        <span class="badge bg-success">Approuvée</span>
                                    {% elseif request.status == 'REJECTED' %}
                                        <span class="badge bg-danger">Refusée</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ request.status }}</span>
                                    {% endif %}
                                    <br>
                                    <strong>Publié par:</strong> {{ request.publisher ?: 'Anonyme' }}<br>
                                    <strong>Date de création:</strong> {{ request.createdAt ? request.createdAt|date('d/m/Y H:i') : '-' }}
                                </div>
                            </div>
                            
                            {% if request.latitude and request.longitude %}
                                <div class="mt-3">
                                    <strong>Coordonnées GPS:</strong> {{ request.latitude }}, {{ request.longitude }}
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header">
                                    <h5>Actions</h5>
                                </div>
                                <div class="card-body">
                                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                        <a href="{{ path('apply_collaboration', {'id': request.id}) }}" 
                                           class="btn btn-primary btn-block mb-2">Postuler à cette offre</a>
                                    {% else %}
                                        <a href="{{ path('app_login') }}" 
                                           class="btn btn-outline-primary btn-block mb-2">Connectez-vous pour postuler</a>
                                    {% endif %}
                                    
                                    <a href="{{ path('collab_request_list') }}" 
                                       class="btn btn-secondary btn-block">Retour à la liste</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
