{% set from_admin = app.request.query.get('from') == 'admin' %}
{% extends from_admin ? 'layouts/admin.html.twig' : 'layouts/front.html.twig' %}

{% block page_title %}Liste utilisateurs | AgriFlow{% endblock %}
{% block admin_title %}Utilisateurs{% endblock %}
{% block admin_subtitle %}Gestion des comptes et verifications{% endblock %}
{% block body_class %}{{ from_admin ? 'agf-admin bg-light' : 'agf-front' }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .users-panel {
        width: 100%;
    }

    .users-toolbar .form-control {
        min-height: 42px;
    }

    .users-table-wrap {
        overflow-x: auto;
    }

    .users-table {
        min-width: 1380px;
    }

    .users-table th,
    .users-table td {
        vertical-align: middle;
        white-space: nowrap;
    }

    .users-table .email-cell {
        max-width: 240px;
        white-space: normal;
        overflow-wrap: anywhere;
    }

    .users-table .actions-cell {
        min-width: 130px;
    }

    .user-thumb {
        width: 72px;
        height: 46px;
        border-radius: 8px;
        border: 1px solid #dfe5ea;
        object-fit: contain;
        background: #fff;
        display: block;
    }

    .zoom-trigger {
        border: 0;
        background: transparent;
        padding: 0;
        border-radius: 8px;
        cursor: zoom-in;
    }

    .role-pill,
    .verify-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 26px;
        padding: 0 10px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        white-space: nowrap;
    }

    .role-admin { color: #1d5f3a; background: #e8f4ed; }
    .role-expert { color: #0b5cad; background: #eaf2fb; }
    .role-agriculteur { color: #8d6e63; background: #f4ece8; }

    .verify-ok { color: #1b5e20; background: #e8f5e9; }
    .verify-ko { color: #c62828; background: #ffebee; }

    .users-count {
        color: #6c757d;
        font-size: 0.92rem;
    }

    .users-pagination {
        display: flex;
        justify-content: center;
        margin-top: 14px;
    }

    .users-pagination .pagination {
        margin-bottom: 0;
    }

    .image-lightbox {
        position: fixed;
        inset: 0;
        z-index: 1200;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(0, 0, 0, 0.72);
        backdrop-filter: blur(2px);
    }

    .image-lightbox.is-open {
        display: flex;
    }

    .image-lightbox__dialog {
        width: min(92vw, 1100px);
        max-height: 88vh;
        border-radius: 14px;
        overflow: hidden;
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .image-lightbox__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 12px;
        color: #fff;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .image-lightbox__close {
        border: 0;
        width: 30px;
        height: 30px;
        border-radius: 999px;
        color: #fff;
        background: rgba(255, 255, 255, 0.16);
        cursor: pointer;
        line-height: 1;
        font-size: 1.2rem;
    }

    .image-lightbox__body {
        display: grid;
        place-items: center;
        padding: 14px;
        max-height: calc(88vh - 52px);
        overflow: auto;
    }

    .image-lightbox__img {
        max-width: 100%;
        max-height: calc(88vh - 90px);
        border-radius: 10px;
        background: #fff;
        object-fit: contain;
    }

    .lightbox-open {
        overflow: hidden;
    }
</style>
{% endblock %}

{% block admin_body %}
    {{ block('users_panel') }}
{% endblock %}

{% block front_body %}
<section class="section">
    <div class="container-fluid px-3 px-xl-4">
        {{ block('users_panel') }}
    </div>
</section>
{% endblock %}

{% block users_panel %}
<div class="users-panel">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-2 users-toolbar align-items-center">
                <div class="col-12 col-xl">
                    <input id="searchField" type="text" class="form-control" placeholder="Rechercher par nom, prenom, email ou role...">
                </div>
                <div class="col-6 col-md-auto">
                    <button id="searchBtn" class="btn btn-success w-100" type="button">Rechercher</button>
                </div>
                <div class="col-6 col-md-auto">
                    <button id="refreshBtn" class="btn btn-outline-primary w-100" type="button">Rafraichir</button>
                </div>
                <div class="col-12 col-md-auto ms-md-auto">
                    <a class="btn btn-outline-success w-100" href="{{ path('app_profile') }}">Retour profil</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="users-table-wrap">
                <table class="table table-hover align-middle mb-0 users-table">
                    <thead class="table-light">
                        <tr>
                            <th>Nom</th>
                            <th>Prenom</th>
                            <th>CIN</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Date creation</th>
                            <th>Verification</th>
                            <th>Signature</th>
                            <th>Carte pro</th>
                            <th>Certification</th>
                            <th>Adresse</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        {% for u in users %}
                            {% set rowRoleRaw = (u.role ?? '')|upper %}
                            {% set rowRole = rowRoleRaw starts with 'ROLE_' ? rowRoleRaw|replace({'ROLE_': ''}) : rowRoleRaw %}
                            <tr class="user-row" data-search="{{ (u.nom ~ ' ' ~ u.prenom ~ ' ' ~ u.email ~ ' ' ~ rowRole)|lower }}">
                                <td class="fw-semibold">{{ u.nom ?: '-' }}</td>
                                <td class="fw-semibold">{{ u.prenom ?: '-' }}</td>
                                <td class="text-muted">{{ u.cin ?: '-' }}</td>
                                <td class="email-cell">{{ u.email ?: '-' }}</td>
                                <td>
                                    {% if rowRole == 'ADMIN' %}
                                        <span class="role-pill role-admin">ADMIN</span>
                                    {% elseif rowRole == 'EXPERT' %}
                                        <span class="role-pill role-expert">EXPERT</span>
                                    {% elseif rowRole == 'AGRICULTEUR' %}
                                        <span class="role-pill role-agriculteur">AGRICULTEUR</span>
                                    {% else %}
                                        <span class="role-pill border">{{ rowRole ?: '-' }}</span>
                                    {% endif %}
                                </td>
                                <td>{{ u.dateCreation ? u.dateCreation|date('d/m/Y') : '-' }}</td>
                                <td>
                                    {% if u.verificationStatus %}
                                        <span class="verify-pill {{ u.verificationStatus|lower in ['ok', 'valide', 'verified', 'active', 'approved'] ? 'verify-ok' : 'verify-ko' }}">
                                            {{ u.verificationStatus|upper }}
                                        </span>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {% if u.signature %}
                                        <button type="button" class="zoom-trigger" data-zoom-src="{{ path('app_admin_user_image', {id: u.id, type: 'signature'}) }}" data-zoom-title="Signature - {{ (u.nom ~ ' ' ~ u.prenom)|trim ?: 'Utilisateur' }}">
                                            <img class="user-thumb" src="{{ path('app_admin_user_image', {id: u.id, type: 'signature'}) }}" alt="Signature">
                                        </button>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {% if rowRole == 'AGRICULTEUR' and u.cartePro %}
                                        <button type="button" class="zoom-trigger" data-zoom-src="{{ path('app_admin_user_image', {id: u.id, type: 'carte'}) }}" data-zoom-title="Carte professionnelle - {{ (u.nom ~ ' ' ~ u.prenom)|trim ?: 'Utilisateur' }}">
                                            <img class="user-thumb" src="{{ path('app_admin_user_image', {id: u.id, type: 'carte'}) }}" alt="Carte pro">
                                        </button>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {% if rowRole == 'EXPERT' and u.certification %}
                                        <button type="button" class="zoom-trigger" data-zoom-src="{{ path('app_admin_user_image', {id: u.id, type: 'certification'}) }}" data-zoom-title="Certification - {{ (u.nom ~ ' ' ~ u.prenom)|trim ?: 'Utilisateur' }}">
                                            <img class="user-thumb" src="{{ path('app_admin_user_image', {id: u.id, type: 'certification'}) }}" alt="Certification">
                                        </button>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>{{ rowRole == 'AGRICULTEUR' ? (u.adresse ?: '-') : '-' }}</td>
                                <td class="text-center actions-cell">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Actions utilisateur">
<!--                                         <button class="btn btn-outline-success" type="button" title="Approuver" disabled>
                                            <i class="bi bi-check2"></i>
                                        </button>
                                        <button class="btn btn-outline-warning" type="button" title="Rejeter" disabled>
                                            <i class="bi bi-x-lg"></i>
                                        </button> -->
                                        <form method="post" action="{{ path('app_admin_user_delete', {id: u.id, from: app.request.query.get('from')}) }}" class="d-inline-block" onsubmit="return confirm('Confirmer la suppression de cet utilisateur ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ u.id) }}">
                                            <button class="btn btn-outline-danger" type="submit" title="Supprimer" {% if app.user and app.user.id == u.id %}disabled{% endif %}>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="12" class="text-center py-4 text-muted">Aucun utilisateur trouve.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="users-pagination">
        {{ knp_pagination_render(users) }}
    </div>

    <p id="countLabel" class="users-count mt-3 mb-0" data-total="{{ users.getTotalItemCount }}">{{ users.getTotalItemCount }} utilisateur(s) au total</p>

    <div id="imageLightbox" class="image-lightbox" aria-hidden="true">
        <div class="image-lightbox__dialog" role="dialog" aria-modal="true" aria-labelledby="imageLightboxTitle">
            <div class="image-lightbox__header">
                <span id="imageLightboxTitle">Apercu image</span>
                <button type="button" class="image-lightbox__close" aria-label="Fermer">&times;</button>
            </div>
            <div class="image-lightbox__body">
                <img id="imageLightboxImg" class="image-lightbox__img" src="" alt="Apercu">
            </div>
        </div>
    </div>

    <script>
    (function () {
        const searchField = document.getElementById('searchField');
        const searchBtn = document.getElementById('searchBtn');
        const refreshBtn = document.getElementById('refreshBtn');
        const rows = Array.from(document.querySelectorAll('.user-row'));
        const countLabel = document.getElementById('countLabel');
        const lightbox = document.getElementById('imageLightbox');
        const lightboxImg = document.getElementById('imageLightboxImg');
        const lightboxTitle = document.getElementById('imageLightboxTitle');
        const lightboxClose = lightbox ? lightbox.querySelector('.image-lightbox__close') : null;

        function openLightbox(src, title) {
            if (!lightbox || !lightboxImg || !lightboxTitle) {
                return;
            }

            lightboxImg.setAttribute('src', src);
            lightboxImg.setAttribute('alt', title || 'Apercu image');
            lightboxTitle.textContent = title || 'Apercu image';
            lightbox.classList.add('is-open');
            lightbox.setAttribute('aria-hidden', 'false');
            document.body.classList.add('lightbox-open');
        }

        function closeLightbox() {
            if (!lightbox || !lightboxImg) {
                return;
            }

            lightbox.classList.remove('is-open');
            lightbox.setAttribute('aria-hidden', 'true');
            lightboxImg.setAttribute('src', '');
            document.body.classList.remove('lightbox-open');
        }

        function updateCount() {
            const visible = rows.filter(row => row.style.display !== 'none').length;
            const total = Number(countLabel.getAttribute('data-total') || rows.length);
            countLabel.textContent = visible + ' affiche(s) / ' + total + ' utilisateur(s)';
        }

        function applyFilter() {
            const query = (searchField.value || '').trim().toLowerCase();

            rows.forEach(row => {
                const haystack = row.getAttribute('data-search') || '';
                row.style.display = haystack.includes(query) ? '' : 'none';
            });

            updateCount();
        }

        searchBtn.addEventListener('click', applyFilter);
        searchField.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                applyFilter();
            }
        });

        refreshBtn.addEventListener('click', function () {
            searchField.value = '';
            rows.forEach(row => {
                row.style.display = '';
            });
            updateCount();
        });

        document.addEventListener('click', function (event) {
            const trigger = event.target.closest('.zoom-trigger');
            if (trigger) {
                const src = trigger.getAttribute('data-zoom-src');
                const title = trigger.getAttribute('data-zoom-title');
                if (src) {
                    openLightbox(src, title);
                }
                return;
            }

            if (lightbox && event.target === lightbox) {
                closeLightbox();
            }
        });

        if (lightboxClose) {
            lightboxClose.addEventListener('click', closeLightbox);
        }

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeLightbox();
            }
        });

        updateCount();
    })();
    </script>
</div>
{% endblock %}