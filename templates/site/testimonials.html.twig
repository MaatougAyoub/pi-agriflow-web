{% extends 'layouts/front.html.twig' %}

{% block page_title %}Retours d utilisation - AgriFlow{% endblock %}

{% block front_hero %}
    <section class="section agf-page-hero">
        <div class="container text-center">
            <span class="agf-eyebrow text-success">Retours d utilisation</span>
            <h1 class="display-6 mb-3">Des profils differents, un meme besoin : acceder vite a la bonne offre.</h1>
            <p class="lead text-muted mb-0">
                AgriFlow repond aussi bien aux besoins des clients qu a ceux des vendeurs et des proprietaires de materiel.
            </p>
        </div>
    </section>
{% endblock %}

{% block front_body %}
    <section class="section pt-0">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="agf-quote-card h-100">
                        <h3 class="h5">Producteur</h3>
                        <p class="mb-0">
                            Je peux publier mes produits plus facilement et voir rapidement quelles demandes sont en attente.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="agf-quote-card h-100">
                        <h3 class="h5">Client</h3>
                        <p class="mb-0">
                            Je trouve plus vite une annonce utile et je comprends immediatement le prix avant d envoyer ma demande.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="agf-quote-card h-100">
                        <h3 class="h5">Proprietaire de materiel</h3>
                        <p class="mb-0">
                            Je peux mettre en location mon materiel et suivre les reservations depuis un espace professionnel dedie.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
