{% extends 'layouts/front.html.twig' %}

{% block page_title %}Retours d utilisation - AgriFlow{% endblock %}

{% block front_hero %}
    <section class="section agf-page-hero">
        <div class="container text-center">
            <span class="agf-eyebrow text-success">Retours d’utilisation</span>
            <h1 class="display-6 mb-3">Des profils différents, un même besoin: accéder vite à la bonne offre.</h1>
            <p class="lead text-muted mb-0">
                AgriFlow répond aussi bien aux besoins des clients qu’à ceux des vendeurs et des propriétaires de matériel.
            </p>
        </div>
    </section>
{% endblock %}

{% block front_body %}
    <section class="section pt-0">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="agf-quote-card h-100">
                        <h3 class="h5">Producteur</h3>
                        <p class="mb-0">
                            Je peux publier mes produits plus facilement et voir rapidement quelles demandes sont en attente.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="agf-quote-card h-100">
                        <h3 class="h5">Client</h3>
                        <p class="mb-0">
                            Je trouve plus vite une annonce utile et je comprends immédiatement le prix avant d’envoyer ma demande.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="agf-quote-card h-100">
                        <h3 class="h5">Propriétaire de matériel</h3>
                        <p class="mb-0">
                            Je peux mettre en location mon matériel et suivre les réservations depuis un espace professionnel dédié.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
