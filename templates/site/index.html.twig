{% extends 'layouts/front.html.twig' %}

{% block page_title %}Accueil - AgriFlow{% endblock %}

{% block front_hero %}
    <section class="hero section dark-background agf-hero">
        <div class="container">
            <div class="row align-items-center gy-5">
                <div class="col-lg-7">
                    <span class="agf-eyebrow">Plateforme AgriFlow</span>
                    <h1 class="display-5 text-white mb-3">Achetez des produits frais ou louez du matériel agricole en toute simplicité.</h1>
                    <p class="text-white-50 mb-4 agf-hero-text">
                        AgriFlow met en relation producteurs, propriétaires de matériel et clients à travers
                        un catalogue clair, des réservations rapides et un suivi simple des demandes.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="{{ path('app_marketplace_index') }}" class="btn btn-success btn-lg">Découvrir les annonces</a>
                        <a href="{{ path('site_services') }}" class="btn btn-outline-light btn-lg">Voir les services</a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="agf-summary-card">
                        <span class="agf-summary-kicker">Pourquoi choisir AgriFlow</span>
                        <div class="agf-stat-grid">
                            <div class="agf-stat-item">
                                <strong>Vente</strong>
                                <span>Produits agricoles disponibles</span>
                            </div>
                            <div class="agf-stat-item">
                                <strong>Location</strong>
                                <span>Matériel prêt à l’emploi</span>
                            </div>
                            <div class="agf-stat-item">
                                <strong>Réservation</strong>
                                <span>Demande rapide depuis la fiche</span>
                            </div>
                            <div class="agf-stat-item">
                                <strong>Suivi</strong>
                                <span>Gestion simple des demandes</span>
                            </div>
                        </div>
                        <p class="agf-summary-note mb-0">
                            Une seule plateforme pour publier, rechercher, réserver et suivre les offres du secteur agricole.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block front_body %}
    <section class="section">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="agf-soft-card h-100">
                        <div class="agf-icon-badge"><i class="bi bi-card-checklist"></i></div>
                        <h3 class="h4">Catalogue clair</h3>
                        <p class="mb-0">
                            Les annonces affichent les prix, la disponibilité, la catégorie, la localisation et les visuels utiles dès le premier écran.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="agf-soft-card h-100">
                        <div class="agf-icon-badge"><i class="bi bi-calendar-check"></i></div>
                        <h3 class="h4">Réservation rapide</h3>
                        <p class="mb-0">
                            Chaque demande se fait depuis la fiche annonce avec les dates, la quantité souhaitée et un total calculé automatiquement.
                        </p>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="agf-soft-card h-100">
                        <div class="agf-icon-badge"><i class="bi bi-columns-gap"></i></div>
                        <h3 class="h4">Espace vendeur</h3>
                        <p class="mb-0">
                            Les vendeurs et propriétaires de matériel disposent d’un espace dédié pour gérer leurs annonces et suivre les demandes.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section pt-0">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <img src="{{ asset('template/assets/img/hero_3.jpg') }}" alt="Irrigation agricole" class="img-fluid agf-section-image">
                </div>
                <div class="col-lg-6">
                    <span class="agf-page-kicker">Pensé pour le terrain</span>
                    <h2 class="mb-3">Des offres utiles pour les besoins agricoles du quotidien</h2>
                    <p>
                        Qu’il s’agisse de louer un tracteur, de réserver une pompe d’irrigation ou d’acheter un lot de produits frais,
                        l’utilisateur retrouve une interface simple et rapide à comprendre.
                    </p>
                    <ul class="agf-check-list">
                        <li>Recherche rapide par titre, catégorie ou localisation</li>
                        <li>Fiches annonce avec prix, stock et disponibilité</li>
                        <li>Demande de réservation directement depuis la fiche annonce</li>
                        <li>Suivi des annonces et des demandes côté vendeur</li>
                    </ul>
                    <a href="{{ path('site_about') }}" class="btn btn-outline-success mt-2">En savoir plus</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
