{% extends 'base.html.twig' %}

{% block admin_title %}Espace admin{% endblock %}
{% block admin_heading %}{{ block('admin_title') }}{% endblock %}
{% block admin_browser_title %}{{ block('admin_title') }} | AgriFlow{% endblock %}
{% block title %}{% block page_title %}{{ block('admin_browser_title') }}{% endblock %}{% endblock %}
{% block body_class %}agf-admin bg-light{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Marcellus&display=swap" rel="stylesheet">
    <link href="{{ asset('template/assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('template/assets/vendor/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
    {% set current_route = app.request.attributes.get('_route') %}
    <div class="container-fluid">
        <div class="row min-vh-100">
            <aside class="col-lg-2 agf-sidebar text-white p-4">
                <a href="{{ path('app_admin_dashboard') }}" class="text-white text-decoration-none d-block mb-4">
                    <span class="h4 d-block mb-1">AgriFlow</span>
                    <small>Espace gestion</small>
                </a>

                <nav class="nav flex-column gap-2">
                    <a class="nav-link text-white px-0 {{ current_route == 'app_admin_dashboard' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_dashboard') }}">
                        <i class="bi bi-speedometer2 me-2"></i>Tableau de bord
                    </a>
                    <a class="nav-link text-white px-0 {{ current_route starts with 'app_admin_annonce_' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_annonce_index') }}">
                        <i class="bi bi-grid me-2"></i>Annonces
                    </a>
                    <a class="nav-link text-white px-0 {{ current_route starts with 'app_admin_reservation_' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_reservation_index') }}">
                        <i class="bi bi-calendar-check me-2"></i>Reservations
                    </a>
                    <a class="nav-link text-white px-0 {{ current_route starts with 'app_admin_parcelle_' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_parcelle_index') }}">
                        <i class="bi bi-bounding-box me-2"></i>Parcelles
                    </a>
                    <a class="nav-link text-white px-0 {{ current_route starts with 'app_admin_culture_' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_culture_index') }}">
                        <i class="bi bi-flower1 me-2"></i>Cultures
                    </a>
                    <a class="nav-link text-white px-0 {{ current_route == 'app_admin_stats' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_stats') }}">
                        <i class="bi bi-bar-chart-line me-2"></i>Statistiques parcelles et cultures
                    </a>
                    <a class="nav-link text-white px-0 {{ current_route == 'app_admin_users' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_users', {from: 'admin'}) }}">
                        <i class="bi bi-people me-2"></i>Utilisateurs
                    </a>
                    <a class="nav-link text-white px-0 {{ current_route starts with 'app_admin_collab_' or current_route starts with 'admin_collab_' ? 'fw-semibold text-warning' : '' }}" href="{{ path('app_admin_collab_index') }}">
                        <i class="bi bi-people me-2"></i>Collaborations
                    </a>
                    <a class="nav-link text-white px-0" href="{{ path('app_marketplace_index') }}">
                        <i class="bi bi-box-arrow-up-right me-2"></i>Ouvrir le site
                    </a>
                </nav>
            </aside>

            <div class="col-lg-10 p-0">
                <header class="bg-white border-bottom px-4 py-3 d-flex justify-content-between align-items-center gap-3 flex-wrap">
                    <div>
                        <h1 class="h4 mb-1">{{ block('admin_heading') }}</h1>
                        <p class="text-muted mb-0">{% block admin_subtitle %}Gestion des annonces et des reservations{% endblock %}</p>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        {% block admin_actions %}{% endblock %}
                        <a href="{{ path('app_marketplace_index') }}" class="btn btn-outline-success">
                            Retour au site
                        </a>
                    </div>
                </header>

                <div class="p-4">
                    {% block admin_body %}{% endblock %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
