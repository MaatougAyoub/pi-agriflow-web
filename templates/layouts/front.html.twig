{% extends 'base.html.twig' %}

{% block title %}{% block page_title %}Marketplace AgriFlow{% endblock %}{% endblock %}
{% block body_class %}agf-front{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Marcellus&display=swap" rel="stylesheet">
    <link href="{{ asset('template/assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('template/assets/vendor/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">
    <link href="{{ asset('template/assets/vendor/aos/aos.css') }}" rel="stylesheet">
    <link href="{{ asset('template/assets/css/main.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
    {% set current_route = app.request.attributes.get('_route') %}
    <header class="header d-flex align-items-center position-relative">
        <div class="container-fluid container-xl position-relative d-flex align-items-center justify-content-between">
            <a href="{{ path('site_home') }}" class="logo d-flex align-items-center">
                <img src="{{ asset('template/assets/img/logo2-header.png') }}" alt="AgriFlow">
            </a>

            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="{{ path('site_home') }}" class="{{ current_route == 'site_home' ? 'active' : '' }}">Accueil</a></li>
                    <li><a href="{{ path('app_marketplace_index') }}" class="{{ current_route starts with 'app_marketplace_' ? 'active' : '' }}">Marketplace</a></li>
                    <li><a href="{{ path('app_collab_index') }}" class="{{ current_route starts with 'app_collab_' ? 'active' : '' }}">Collaborations</a></li>
                    {% if is_granted('ROLE_AGRICULTEUR') %}
                        <li><a href="{{ path('app_parcelle_index') }}" class="{{ current_route starts with 'app_parcelle_' or current_route starts with 'app_culture_' ? 'active' : '' }}">Parcelles & Cultures</a></li>
                    {% endif %}
                    <li><a href="{{ path('site_services') }}" class="{{ current_route == 'site_services' ? 'active' : '' }}">Services</a></li>

                    {% if app.user %}
                    <li class="dropdown">
                        <a href="{{ path('irrigation_dashboard') }}" class="{{ current_route starts with 'irrigation_' or current_route starts with 'plan_' or current_route starts with 'expert_' or current_route starts with 'agriculteur_' ? 'active' : '' }}">
                            <span>💧 Irrigation</span>
                            <i class="bi bi-chevron-down toggle-dropdown"></i>
                        </a>
                        <ul>
                            {% if is_granted('ROLE_EXPERT') %}
                                <li><a href="{{ path('expert_index') }}">🏠 Dashboard</a></li>
                            {% else %}
                                <li><a href="{{ path('dashboard_index') }}">📊 Statistiques</a></li>
                            {% endif %}
                            {% if is_granted('ROLE_AGRICULTEUR') or is_granted('ROLE_EXPERT') %}
                            <li><a href="{{ path('app_culture_index') }}">🌱 Cultures</a></li>
                            {% endif %}
                            <li>
                                <a href="{{ is_granted('ROLE_EXPERT') ? path('expert_irrigation') : path('agriculteur_irrigation') }}">
                                    💧 Plans d'irrigation
                                </a>
                            </li>
                            {% if is_granted('ROLE_EXPERT') %}
                                <li><a href="{{ path('expert_diagnostics') }}">📝 Diagnostics</a></li>
                                <li><a href="{{ path('expert_produits') }}">💊 Produits phyto</a></li>
                            {% else %}
                                <li><a href="{{ path('agriculteur_diagnostics') }}">📝 Mes diagnostics</a></li>
                                <li><a href="{{ path('agriculteur_diagnostic_new') }}">➕ Nouveau diagnostic</a></li>
                            {% endif %}
                        </ul>
                    </li>
                    {% endif %}

                    <li><a href="{{ path('site_about') }}" class="{{ current_route == 'site_about' ? 'active' : '' }}">A propos</a></li>
                    <li><a href="{{ path('site_contact') }}" class="{{ current_route == 'site_contact' ? 'active' : '' }}">Contact</a></li>
                    {% if app.user %}
                        <li><a href="{{ path('app_profile') }}" class="{{ current_route starts with 'app_profile' ? 'active' : '' }}">Profil</a></li>
                        <li><a href="{{ path('app_reclamation_index') }}" class="{{ current_route starts with 'app_reclamation_' ? 'active' : '' }}">Reclamations</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_AGRICULTEUR') %}
                        <li class="d-xl-none"><a href="{{ path('app_seller_annonce_index') }}" class="{{ current_route starts with 'app_seller_' ? 'active' : '' }}">Mon espace vendeur</a></li>
                        <li class="d-xl-none"><a href="{{ path('app_reservation_my') }}" class="{{ current_route == 'app_reservation_my' ? 'active' : '' }}">Mes reservations</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="d-xl-none"><a href="{{ path('app_admin_dashboard') }}" class="{{ current_route starts with 'app_admin_' ? 'active' : '' }}">Espace admin</a></li>
                        <li class="d-xl-none"><a href="{{ path('app_admin_users') }}" class="{{ current_route starts with 'app_admin_user' ? 'active' : '' }}">Liste des utilisateurs</a></li>
                    {% endif %}
                    {% if app.user %}
                        <li class="d-xl-none"><a href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Deconnexion</a></li>
                    {% else %}
                        <li class="d-xl-none"><a href="{{ path('app_login') }}" class="{{ current_route == 'app_login' ? 'active' : '' }}"><i class="bi bi-box-arrow-in-right me-2"></i>Connexion</a></li>
                    {% endif %}
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>

            <div class="agf-header-actions d-none d-xl-flex">
                {% if is_granted('ROLE_AGRICULTEUR') %}
                    <a href="{{ path('app_seller_annonce_index') }}" class="agf-pro-link agf-pro-link--seller {{ current_route starts with 'app_seller_' ? 'active' : '' }}">
                        <i class="bi bi-shop-window"></i>
                        <span>Mon espace vendeur</span>
                    </a>
                    <a href="{{ path('app_reservation_my') }}" class="agf-pro-link agf-pro-link--reservations {{ current_route == 'app_reservation_my' ? 'active' : '' }}">
                        <i class="bi bi-calendar-check"></i>
                        <span>Mes reservations</span>
                    </a>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_dashboard') }}" class="agf-pro-link agf-pro-link--admin {{ current_route starts with 'app_admin_' ? 'active' : '' }}">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard admin</span>
                    </a>
                    <a href="{{ path('app_admin_users') }}" class="agf-pro-link agf-pro-link--users {{ current_route starts with 'app_admin_user' ? 'active' : '' }}">
                        <i class="bi bi-people"></i>
                        <span>Utilisateurs</span>
                    </a>
                {% endif %}
                {% if app.user %}
                    <a href="{{ path('app_logout') }}" class="agf-auth-link agf-auth-link--logout">
                        <i class="bi bi-box-arrow-right"></i>
                        Deconnexion
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="agf-auth-link agf-auth-link--login {{ current_route == 'app_login' ? 'active' : '' }}">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Connexion
                    </a>
                {% endif %}
            </div>
        </div>
    </header>

    <main class="main">
        {% block front_hero %}{% endblock %}
        {% block front_body %}{% endblock %}
    </main>

    <footer id="footer" class="footer dark-background">
        <div class="footer-top">
            <div class="container">
                <div class="row gy-4">
                    <div class="col-lg-4 col-md-6 footer-about">
                        <a href="{{ path('app_marketplace_index') }}" class="logo d-flex align-items-center">
                            <span class="sitename">AgriFlow</span>
                        </a>
                        <div class="footer-contact pt-3">
                            <p>Plateforme de mise en relation</p>
                            <p>entre agriculteurs, vendeurs et clients</p>
                            <p class="mt-3">Vente, location et suivi des demandes</p>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6 footer-links">
                        <h4>Liens rapides</h4>
                        <ul>
                            <li><a href="{{ path('site_home') }}">Accueil</a></li>
                            <li><a href="{{ path('app_marketplace_index') }}">Catalogue</a></li>
                            <li><a href="{{ path('site_services') }}">Services</a></li>
                            <li><a href="{{ path('site_contact') }}">Contact</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-4 col-md-12 footer-links">
                        {% if is_granted('ROLE_ADMIN') %}
                            <h4>Espace vendeur</h4>
                            <ul>
                                <li><a href="{{ path('app_admin_dashboard') }}">Tableau de bord</a></li>
                                <li><a href="{{ path('app_admin_annonce_index') }}">Gerer les annonces</a></li>
                                <li><a href="{{ path('app_admin_reservation_index') }}">Suivre les reservations</a></li>
                            </ul>
                        {% elseif is_granted('ROLE_AGRICULTEUR') %}
                            <h4>Mon espace vendeur</h4>
                            <ul>
                                <li><a href="{{ path('app_seller_annonce_index') }}">Mes annonces</a></li>
                                <li><a href="{{ path('app_seller_request_index') }}">Demandes recues</a></li>
                                <li><a href="{{ path('app_parcelle_index') }}">Parcelles & cultures</a></li>
                                <li><a href="{{ path('app_reservation_my') }}">Mes reservations</a></li>
                                <li><a href="{{ path('app_profile') }}">Mon profil</a></li>
                                <li><a href="{{ path('app_reclamation_index') }}">Mes reclamations</a></li>
                            </ul>
                        {% else %}
                            <h4>Besoin d'aide ?</h4>
                            <ul>
                                <li><a href="{{ path('app_login') }}">Se connecter</a></li>
                                <li><a href="{{ path('site_contact') }}">Nous contacter</a></li>
                            </ul>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="{{ asset('template/assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ asset('template/assets/vendor/aos/aos.js') }}"></script>
    <script src="{{ asset('template/assets/js/main.js') }}"></script>
{% endblock %}
