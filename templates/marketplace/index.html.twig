{% extends 'layouts/front.html.twig' %}

{% block page_title %}Marketplace AgriFlow{% endblock %}

{% block front_hero %}
    <section class="hero section dark-background agf-hero">
        <div class="container">
            <div class="row align-items-center gy-5">
                <div class="col-lg-7">
                    <span class="agf-eyebrow">AgriFlow Marketplace</span>
                    <h1 class="display-5 text-white mb-3">Trouvez du matériel, des produits et des offres de location en quelques clics.</h1>
                    <p class="text-white-50 mb-4 agf-hero-text">
                        AgriFlow facilite la mise en relation entre agriculteurs et clients avec des annonces claires,
                        un suivi simple des demandes et un parcours de réservation direct.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="#liste-annonces" class="btn btn-success btn-lg">Parcourir les annonces</a>
                        <a href="{{ path('site_contact') }}" class="btn btn-outline-light btn-lg">Besoin d’aide ?</a>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="agf-summary-card">
                        <span class="agf-summary-kicker">Aperçu rapide</span>
                        <div class="agf-stat-grid">
                            <div class="agf-stat-item">
                                <strong>{{ stats.total }}</strong>
                                <span>Annonces disponibles</span>
                            </div>
                            <div class="agf-stat-item">
                                <strong>{{ stats.vente }}</strong>
                                <span>Offres de vente</span>
                            </div>
                            <div class="agf-stat-item">
                                <strong>{{ stats.location }}</strong>
                                <span>Offres de location</span>
                            </div>
                            <div class="agf-stat-item">
                                <strong>{{ stats.zones }}</strong>
                                <span>Zones couvertes</span>
                            </div>
                        </div>
                        <p class="agf-summary-note mb-0">
                            Filtrez les annonces, consultez les détails et envoyez une demande de réservation depuis la fiche produit.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block front_body %}
    <section class="section" id="liste-annonces">
        <div class="container">
            <div class="row g-4 align-items-end mb-5">
                <div class="col-lg-8">
                    <h2 class="mb-2">Annonces disponibles</h2>
                    <p class="text-muted mb-0">Consultez les offres publiées, filtrez par type et accédez rapidement aux détails.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="{{ path('app_admin_annonce_index') }}" class="btn btn-outline-success">Ouvrir la gestion</a>
                </div>
            </div>

            <form method="get" class="row g-3 agf-filter-card mb-5">
                <div class="col-md-6">
                    <label for="q" class="form-label">Recherche</label>
                    <input id="q" name="q" type="text" value="{{ filters.q }}" class="form-control" placeholder="titre, catégorie ou localisation">
                </div>
                <div class="col-md-4">
                    <label for="type" class="form-label">Type</label>
                    <select id="type" name="type" class="form-select">
                        <option value="">Tous</option>
                        {% for type in types %}
                            <option value="{{ type.value }}" {{ filters.type == type.value ? 'selected' : '' }}>
                                {{ type.label() }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <label class="form-label d-none d-md-block">&nbsp;</label>
                    <button class="btn btn-success">Filtrer</button>
                </div>
            </form>

            <div class="row g-4">
                {% for annonce in annonces %}
                    {% set visual = visuals[annonce.id] ?? {
                        image: 'template/assets/img/hero_4.jpg',
                        alt: annonce.titre,
                        position: 'center center'
                    } %}
                    <div class="col-xl-4 col-md-6">
                        <article class="card h-100 border-0 shadow-sm agf-market-card">
                            <div class="agf-card-image-wrap">
                                <img
                                    src="{{ asset(visual.image) }}"
                                    alt="{{ visual.alt }}"
                                    class="agf-card-image"
                                    loading="lazy"
                                    style="object-position: {{ visual.position }};"
                                >
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="badge text-bg-success-subtle text-success">{{ annonce.type.label() }}</span>
                                    <span class="badge text-bg-light">{{ annonce.statut.label() }}</span>
                                </div>
                                <h3 class="h5">{{ annonce.titre }}</h3>
                                <p class="text-muted small mb-2">{{ annonce.categorie }} - {{ annonce.localisation }}</p>
                                <p class="flex-grow-1">{{ annonce.description|length > 120 ? annonce.description|slice(0, 120) ~ '...' : annonce.description }}</p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <strong class="text-success">{{ annonce.prix }} TND / {{ annonce.unitePrix }}</strong>
                                    <a href="{{ path('app_marketplace_show', {id: annonce.id}) }}" class="btn btn-sm btn-dark">Voir l’annonce</a>
                                </div>
                            </div>
                        </article>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="alert alert-info mb-0">
                            Aucune annonce ne correspond aux filtres actuels.
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
