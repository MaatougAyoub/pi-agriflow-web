{% extends 'layouts/front.html.twig' %}

{% block page_title %}{{ annonce.titre }} - AgriFlow{% endblock %}

{% block front_body %}
    {% set visualSrc = visual.isExternal ? visual.image : asset(visual.image) %}
    {% set normalizedLocation = annonce.localisationNormalisee ?: annonce.localisation %}
    {% set hasMapCoordinates = annonce.latitude is not null and annonce.longitude is not null %}
    {% set environment = environmentInsights|default(null) %}
    <section class="section pt-5">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-7">
                    <div class="agf-detail-image-wrap">
                        <img
                            src="{{ visualSrc }}"
                            alt="{{ visual.alt }}"
                            class="agf-detail-image"
                            referrerpolicy="no-referrer"
                            style="object-position: {{ visual.position }};"
                        >
                    </div>

                    <div class="d-flex gap-2 flex-wrap mb-3">
                        <span class="badge text-bg-success-subtle text-success">{{ annonce.type.label() }}</span>
                        <span class="badge text-bg-light">{{ annonce.statut.label() }}</span>
                        <span class="badge text-bg-light">{{ annonce.categorie }}</span>
                    </div>

                    <h2 class="mb-3">{{ annonce.titre }}</h2>
                    <p class="lead text-muted">{{ annonce.description }}</p>

                    <div class="row g-3 mt-4">
                        <div class="col-md-4">
                            <div class="agf-info-box">
                                <span class="small text-muted d-block">Prix</span>
                                <strong>{{ annonce.prix }} TND / {{ annonce.unitePrix }}</strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="agf-info-box">
                                <span class="small text-muted d-block">Stock</span>
                                <strong>{{ annonce.quantiteDisponible }} unite(s)</strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="agf-info-box">
                                <span class="small text-muted d-block">Localisation</span>
                                <strong>{{ normalizedLocation }}</strong>
                                {% if hasMapCoordinates %}
                                    <a
                                        href="https://www.openstreetmap.org/?mlat={{ annonce.latitude }}&mlon={{ annonce.longitude }}#map=13/{{ annonce.latitude }}/{{ annonce.longitude }}"
                                        target="_blank"
                                        rel="noreferrer"
                                        class="agf-map-link"
                                    >
                                        Voir sur la carte
                                    </a>
                                {% else %}
                                    <a
                                        href="https://www.openstreetmap.org/search?query={{ normalizedLocation|url_encode }}"
                                        target="_blank"
                                        rel="noreferrer"
                                        class="agf-map-link"
                                    >
                                        Voir sur la carte
                                    </a>
                                    {% if annonce.localisationNormalisee %}
                                        <span class="agf-map-note">Localisation normalisee automatiquement via OpenStreetMap.</span>
                                    {% endif %}
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {% if environment and hasMapCoordinates %}
                        {# api: houni nwarri meteo w qualite air men Open-Meteo ken annonce 3andha coordonnees #}
                        <div class="agf-environment-panel mt-4">
                            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                                <div>
                                    <span class="agf-page-kicker mb-2">APIs externes</span>
                                    <h3 class="h5 mb-1">Meteo et qualite de l air</h3>
                                    <p class="small text-muted mb-0">Donnees courtes calculees depuis la localisation de l annonce.</p>
                                </div>
                                <span class="badge text-bg-light">{{ environment.source }}</span>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="agf-info-box h-100">
                                        <span class="small text-muted d-block">Open-Meteo Forecast</span>
                                        {% if environment.weather.available %}
                                            <strong>{{ environment.weather.temperature ?? 'N/A' }} deg C - {{ environment.weather.label }}</strong>
                                            <div class="small text-muted mt-2">
                                                Vent {{ environment.weather.windSpeed ?? 'N/A' }} km/h,
                                                humidite {{ environment.weather.humidity ?? 'N/A' }}%,
                                                pluie {{ environment.weather.precipitation ?? 'N/A' }} mm
                                            </div>
                                        {% else %}
                                            <strong>Indisponible</strong>
                                            <div class="small text-muted mt-2">{{ environment.weather.message }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="agf-info-box h-100">
                                        <span class="small text-muted d-block">Open-Meteo Air Quality</span>
                                        {% if environment.airQuality.available %}
                                            <strong>AQI {{ environment.airQuality.europeanAqi ?? 'N/A' }} - {{ environment.airQuality.level }}</strong>
                                            <div class="small text-muted mt-2">
                                                PM10 {{ environment.airQuality.pm10 ?? 'N/A' }},
                                                PM2.5 {{ environment.airQuality.pm25 ?? 'N/A' }}
                                            </div>
                                        {% else %}
                                            <strong>Indisponible</strong>
                                            <div class="small text-muted mt-2">{{ environment.airQuality.message }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>

                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            {% if isOwnerViewer %}
                                <h3 class="h4 mb-3">Votre annonce</h3>
                                <p class="text-muted small">
                                    Cette fiche vous appartient. Vous pouvez la mettre a jour et suivre les demandes recues
                                    depuis votre espace vendeur.
                                </p>
                                <div class="d-grid gap-2">
                                    <a href="{{ path('app_seller_annonce_edit', {id: annonce.id}) }}" class="btn btn-success">Modifier cette annonce</a>
                                    <a href="{{ path('app_seller_request_index', {annonce: annonce.id}) }}" class="btn btn-outline-secondary">Voir les demandes recues</a>
                                    <a href="{{ path('app_seller_annonce_index') }}" class="btn btn-outline-dark">Retour a mes annonces</a>
                                </div>
                            {% elseif canReserve %}
                                <h3 class="h4 mb-3">Envoyer une demande</h3>
                                <p class="text-muted small">
                                    {% if annonce.isLocation() %}
                                        Choisissez la periode et la quantite souhaitee. Le montant final inclut automatiquement la commission de la plateforme.
                                    {% else %}
                                        Choisissez la quantite souhaitee. La date de demande est enregistree automatiquement et le montant final inclut la commission de la plateforme.
                                    {% endif %}
                                </p>

                                {{ form_start(reservationForm) }}
                                    {% if reservationForm.dateDebut is defined and reservationForm.dateFin is defined %}
                                        <div class="row g-3">
                                            <div class="col-md-6">{{ form_row(reservationForm.dateDebut) }}</div>
                                            <div class="col-md-6">{{ form_row(reservationForm.dateFin) }}</div>
                                        </div>
                                    {% endif %}
                                    <div class="mt-3">{{ form_row(reservationForm.quantite) }}</div>
                                    <div class="mt-3">{{ form_row(reservationForm.message) }}</div>
                                    <button class="btn btn-success w-100">Confirmer la demande</button>
                                {{ form_end(reservationForm) }}
                            {% elseif isAdminViewer %}
                                <h3 class="h4 mb-3">Gestion rapide</h3>
                                <p class="text-muted small">
                                    Vous etes connecte comme administrateur. Cette fiche est visible comme un client, mais la gestion se fait depuis l'espace vendeur.
                                </p>
                                <div class="d-grid gap-2">
                                    <a href="{{ path('app_admin_annonce_edit', {id: annonce.id}) }}" class="btn btn-success">Modifier cette annonce</a>
                                    <a href="{{ path('app_admin_reservation_index') }}" class="btn btn-outline-secondary">Voir les reservations</a>
                                </div>
                            {% elseif isAgriculteurViewer %}
                                <h3 class="h4 mb-3">Annonce non reservable</h3>
                                <p class="text-muted small">
                                    Cette annonce n est plus disponible pour une nouvelle demande. Consultez d autres offres actives du marketplace.
                                </p>
                                <a href="{{ path('app_marketplace_index') }}" class="btn btn-success w-100">Retour au marketplace</a>
                            {% else %}
                                <h3 class="h4 mb-3">Reserver cette annonce</h3>
                                <p class="text-muted small">
                                    Connectez-vous avec un compte agriculteur pour envoyer une demande de reservation.
                                </p>
                                <a href="{{ path('app_login') }}" class="btn btn-success w-100">Se connecter pour reserver</a>
                            {% endif %}
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            {% if isOwnerViewer or isAdminViewer %}
                                <h3 class="h5 mb-3">Demandes recentes</h3>
                                <div class="table-responsive">
                                    <table class="table align-middle mb-0">
                                        <thead>
                                            <tr>
                                                <th>Client</th>
                                                <th>Statut</th>
                                                <th>Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for reservation in recentReservations %}
                                                <tr>
                                                    <td>#{{ reservation.clientId }}</td>
                                                    <td>{{ reservation.statut.label() }}</td>
                                                    <td>{{ reservation.prixTotal }} TND</td>
                                                </tr>
                                            {% else %}
                                                <tr>
                                                    <td colspan="3" class="text-muted">Aucune demande pour le moment.</td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <h3 class="h5 mb-3">Bon a savoir</h3>
                                <ul class="mb-0 ps-3">
                                    <li>Le vendeur confirme ou refuse chaque demande manuellement.</li>
                                    <li>Le total affiche inclut deja la commission de la plateforme.</li>
                                    <li>Le stock disponible est mis a jour seulement apres validation de la demande.</li>
                                    {% if annonce.isLocation() %}
                                        <li>Pour une location, le montant depend de la periode selectionnee.</li>
                                    {% else %}
                                        <li>Pour une vente, la demande se fait sur la quantite sans choisir de periode.</li>
                                    {% endif %}
                                </ul>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section pt-0">
        <div class="container">
            <div class="d-flex justify-content-between align-items-end gap-3 flex-wrap mb-4">
                <div>
                    <span class="agf-page-kicker mb-2">Fonctionnalite avancee</span>
                    <h3 class="mb-2">Offres similaires</h3>
                    <p class="text-muted mb-0">Suggestions du meme type et de la meme categorie pour prolonger la navigation.</p>
                </div>
                <a href="{{ path('app_marketplace_index', {type: annonce.type.value}) }}" class="btn btn-outline-success">Voir plus d offres</a>
            </div>

            <div class="row g-4">
                {% for similar in similarAnnonces %}
                    {% set similarVisual = similarVisuals[similar.id] ?? {
                        image: 'template/assets/img/hero_4.jpg',
                        alt: similar.titre,
                        position: 'center center',
                        isExternal: false
                    } %}
                    {% set similarVisualSrc = similarVisual.isExternal ? similarVisual.image : asset(similarVisual.image) %}
                    <div class="col-lg-3 col-md-6">
                        <article class="agf-similar-card h-100">
                            <img
                                src="{{ similarVisualSrc }}"
                                alt="{{ similarVisual.alt }}"
                                class="agf-similar-card__image"
                                loading="lazy"
                                referrerpolicy="no-referrer"
                                style="object-position: {{ similarVisual.position }};"
                            >
                            <div class="agf-similar-card__body">
                                <div class="d-flex gap-2 flex-wrap mb-2">
                                    <span class="badge text-bg-success-subtle text-success">{{ similar.type.label() }}</span>
                                    <span class="badge text-bg-light">{{ similar.categorie }}</span>
                                </div>
                                <h4 class="h6 mb-2">{{ similar.titre }}</h4>
                                <p class="small text-muted mb-3">{{ similar.localisationNormalisee ?: similar.localisation }}</p>
                                <div class="d-flex justify-content-between align-items-center gap-2">
                                    <strong class="text-success">{{ similar.prix }} TND / {{ similar.unitePrix }}</strong>
                                    <a href="{{ path('app_marketplace_show', {id: similar.id}) }}" class="btn btn-sm btn-dark">Voir</a>
                                </div>
                            </div>
                        </article>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="alert alert-light border mb-0">
                            Aucune offre similaire n est disponible pour le moment.
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
