{#
    Fichier : templates/partials/_mercure_notifications.html.twig
    Inclus dans base.html.twig pour tous les utilisateurs connectés
#}
{% if app.user %}
<div id="notif-container" style="
    position: fixed;
    top: 80px;
    right: 20px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 360px;
    pointer-events: none;
"></div>

<style>
.notif-toast {
    background: #ffffff;
    border: 1px solid #dee2e6;
    border-radius: 10px;
    padding: 14px 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    pointer-events: all;
    animation: slideIn 0.3s ease;
    max-width: 360px;
    font-family: 'Segoe UI', sans-serif;
}
.notif-toast.success { border-left: 4px solid #2d6a4f; }
.notif-toast.info    { border-left: 4px solid #0077b6; }
.notif-toast.warning { border-left: 4px solid #ca8a04; }
.notif-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
.notif-body { flex: 1; }
.notif-title { font-weight: 600; font-size: 14px; color: #1a1a1a; margin: 0 0 3px; }
.notif-msg   { font-size: 13px; color: #555; margin: 0; line-height: 1.4; }
.notif-date  { font-size: 11px; color: #999; margin-top: 4px; display: block; }
.notif-close {
    background: none; border: none; cursor: pointer;
    color: #aaa; font-size: 18px; line-height: 1;
    padding: 0; flex-shrink: 0; align-self: flex-start;
}
.notif-close:hover { color: #333; }
@keyframes slideIn {
    from { transform: translateX(120%); opacity: 0; }
    to   { transform: translateX(0);   opacity: 1; }
}
@keyframes slideOut {
    from { transform: translateX(0);   opacity: 1; }
    to   { transform: translateX(120%); opacity: 0; }
}

/* Compteur de notifications dans la navbar (optionnel) */
#notif-badge {
    display: none;
    position: absolute;
    top: -6px; right: -6px;
    background: #dc3545;
    color: white;
    font-size: 11px;
    font-weight: 700;
    border-radius: 50%;
    width: 18px; height: 18px;
    align-items: center;
    justify-content: center;
}
</style>

<script>
(function() {
    const userId  = {{ app.user.id }};
    const isAdmin = {{ is_granted('ROLE_ADMIN') ? 'true' : 'false' }};
    const isExpert = {{ is_granted('ROLE_EXPERT') ? 'true' : 'false' }};
    const mercureUrl = '{{ mercure_url is defined ? mercure_url : "http://localhost:3000/.well-known/mercure" }}';
    const pendingSummaryEndpoint = isAdmin ? '{{ path('app_reclamation_admin_pending_summary') }}' : '';

    let notifCount = 0;
    let lastKnownPendingCount = null;
    let lastKnownPendingId = null;
    let fallbackPollingStarted = false;

    function showToast(data) {
        const container = document.getElementById('notif-container');
        if (!container) return;

        const icons = {
            'nouveau_diagnostic' : '📋',
            'diagnostic_traite'  : '✅',
            'nouveau_plan'       : '💧',
            'plan_mis_a_jour'    : '📊',
            'nouvelle_reclamation': '⚠️',
        };
        const types = {
            'nouveau_diagnostic' : 'info',
            'diagnostic_traite'  : 'success',
            'nouveau_plan'       : 'info',
            'plan_mis_a_jour'    : 'success',
            'nouvelle_reclamation': 'warning',
        };
        const titles = {
            'nouveau_diagnostic' : 'Nouveau diagnostic',
            'diagnostic_traite'  : 'Diagnostic traité',
            'nouveau_plan'       : 'Nouveau plan irrigation',
            'plan_mis_a_jour'    : 'Plan mis à jour',
            'nouvelle_reclamation': 'Nouvelle reclamation',
        };

        const icon  = icons[data.type]  || '🔔';
        const type  = types[data.type]  || 'info';
        const title = titles[data.type] || 'Notification';

        const toast = document.createElement('div');
        toast.className = `notif-toast ${type}`;
        toast.innerHTML = `
            <span class="notif-icon">${icon}</span>
            <div class="notif-body">
                <p class="notif-title">${title}</p>
                <p class="notif-msg">${data.message || ''}</p>
                <span class="notif-date">${data.date || ''}</span>
            </div>
            <button class="notif-close" onclick="this.closest('.notif-toast').remove()">×</button>
        `;

        container.appendChild(toast);
        notifCount++;

        // Sonner si possible
        try {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.frequency.value = 520;
            gain.gain.setValueAtTime(0.1, ctx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
            osc.start(ctx.currentTime);
            osc.stop(ctx.currentTime + 0.4);
        } catch(e) {}

        // Auto-fermer après 6 secondes
        setTimeout(() => {
            toast.style.animation = 'slideOut 0.3s ease forwards';
            setTimeout(() => toast.remove(), 300);
        }, 6000);

        if (data.type === 'nouvelle_reclamation') {
            if (typeof data.id !== 'undefined' && data.id !== null) {
                lastKnownPendingId = Number.parseInt(String(data.id), 10);
            }

            updateReclamationsCounter();
        }
    }

    function updateReclamationsCounter(nextValue = null) {
        const links = document.querySelectorAll('[data-reclamations-link="1"]');

        links.forEach(function (link) {
            const current = Number.parseInt(link.getAttribute('data-pending-count') || '0', 10);
            let nextCount = Number.parseInt(String(nextValue), 10);

            if (Number.isNaN(nextCount)) {
                nextCount = Number.isNaN(current) ? 1 : current + 1;
            }

            link.setAttribute('data-pending-count', String(nextCount));
            link.textContent = `Reclamations(${nextCount})`;
        });

        if (!Number.isNaN(Number.parseInt(String(nextValue), 10))) {
            lastKnownPendingCount = Number.parseInt(String(nextValue), 10);
        }
    }

    function startAdminFallbackPolling() {
        if (!isAdmin || fallbackPollingStarted || pendingSummaryEndpoint === '') {
            return;
        }

        fallbackPollingStarted = true;

        const syncPendingState = async function () {
            try {
                const response = await fetch(pendingSummaryEndpoint, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    credentials: 'same-origin'
                });

                if (!response.ok) {
                    return;
                }

                const payload = await response.json();
                const count = Number.parseInt(String(payload.count ?? 0), 10);
                const latestId = Number.parseInt(String(payload.latest_id ?? 0), 10);

                if (lastKnownPendingCount === null) {
                    lastKnownPendingCount = Number.isNaN(count) ? 0 : count;
                    lastKnownPendingId = Number.isNaN(latestId) ? null : latestId;
                    updateReclamationsCounter(lastKnownPendingCount);

                    return;
                }

                const normalizedCount = Number.isNaN(count) ? lastKnownPendingCount : count;
                const normalizedLatestId = Number.isNaN(latestId) ? null : latestId;

                const hasNewPending = normalizedCount > lastKnownPendingCount
                    && normalizedLatestId !== null
                    && normalizedLatestId !== lastKnownPendingId;

                if (hasNewPending) {
                    showToast({
                        type: 'nouvelle_reclamation',
                        id: normalizedLatestId,
                        message: `Nouvelle reclamation EN_ATTENTE de ${payload.latest_auteur || 'un utilisateur'}: ${payload.latest_titre || ''}`,
                        date: payload.latest_date || ''
                    });
                }

                lastKnownPendingCount = normalizedCount;
                lastKnownPendingId = normalizedLatestId;
                updateReclamationsCounter(lastKnownPendingCount);
            } catch (e) {
                // polling fallback: ignorer silencieusement les erreurs reseau ponctuelles
            }
        };

        void syncPendingState();
        window.setInterval(function () {
            void syncPendingState();
        }, 8000);
    }

    function subscribe(topic) {
        const url = new URL(mercureUrl);
        url.searchParams.append('topic', topic);

        const es = new EventSource(url.toString(), { withCredentials: false });

        es.onopen = function() {
            console.log('[Mercure] Connecté au topic:', topic);
        };

        es.onmessage = function(event) {
            try {
                const data = JSON.parse(event.data);
                console.log('[Mercure] Message reçu:', data);
                showToast(data);
            } catch(e) {
                console.error('[Mercure] Erreur parsing:', e);
            }
        };

        es.onerror = function(err) {
            console.warn('[Mercure] Erreur EventSource:', err);
            // Reconnexion automatique gérée par le navigateur
        };

        return es;
    }

    // Attendre que le DOM soit prêt
    document.addEventListener('DOMContentLoaded', function() {
        if (isAdmin) {
            startAdminFallbackPolling();
            subscribe('admin/reclamations');
            console.log('[Mercure] Admin abonne aux notifications reclamations');
        } else if (isExpert) {
            // Les experts reçoivent les nouveaux diagnostics et plans
            subscribe('diagnostics/nouveau');
            subscribe('irrigation/nouveau');
            console.log('[Mercure] Expert abonné aux topics globaux');
        } else {
            // Les agriculteurs reçoivent leurs notifications personnelles
            subscribe(`agriculteur/${userId}/diagnostics`);
            subscribe(`agriculteur/${userId}/irrigation`);
            console.log(`[Mercure] Agriculteur ${userId} abonné à ses topics`);
        }
    });
})();
</script>
{% endif %}