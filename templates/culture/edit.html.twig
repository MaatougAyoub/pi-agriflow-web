{% extends 'parcelle_culture/layout.html.twig' %}

{% block page_title %}Modifier culture{% endblock %}
{% block hero_title %}Modifier une culture{% endblock %}
{% block hero_subtitle %}Mettez a jour les informations de votre culture{% endblock %}
{% block top_right_action %}
    <a href="{{ path('app_culture_show', {id: culture.id}) }}" class="btn btn-outline-success">Retour au detail</a>
{% endblock %}
{% block hero_size %}pc-hero-medium{% endblock %}

{% block module_body %}
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
            <h1 class="h3 mb-4">Modifier : {{ culture.nom ?: 'Culture #' ~ culture.id }}</h1>
            {% include 'culture/_form.html.twig' with {submit_label: 'Mettre a jour la culture'} %}
        </div>
    </div>
{% endblock %}