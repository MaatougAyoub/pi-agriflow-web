{% form_theme form 'bootstrap_5_layout.html.twig' %}

{{ form_start(form, {'attr': {'novalidate': 'novalidate', 'data-turbo': 'false'}}) }}
  {% include 'partials/_form_error_summary.html.twig' with { form: form } %}

  {% if selected_parcelle %}
    <div class="alert alert-info" id="culture-surface-alert">
      Surface disponible pour <strong id="selected-parcelle-name">{{ selected_parcelle.nom ?: 'Parcelle #' ~ selected_parcelle.id }}</strong>:
      <span id="selected-available-surface">{{ selected_available_surface|default(0)|number_format(0, '.', ' ') }}</span> m&sup2;
    </div>
  {% else %}
    <div class="alert alert-secondary" id="culture-surface-alert">
      Selectionnez une parcelle. Les surfaces disponibles actuelles sont rappelees ci-dessous.
    </div>
  {% endif %}

  {{ form_errors(form) }}

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      {{ form_row(form.parcelleId) }}
      <div class="row">
        <div class="col-md-6">
          {{ form_row(form.nom) }}
        </div>
        <div class="col-md-6">
          {{ form_row(form.typeCulture) }}
        </div>
      </div>
      <div class="row">
        <div class="col-md-6">
          {{ form_row(form.superficie) }}
        </div>
        <div class="col-md-6">
          {{ form_row(form.dateRecolte) }}
        </div>
      </div>
      <div class="row">
        <div class="col-md-6">
          {{ form_row(form.recolteEstime) }}
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <h2 class="h5 mb-3">Surfaces disponibles par parcelle</h2>
      <div class="row g-3">
        {% for parcelle in parcelles %}
          <div class="col-md-6">
            <div class="border rounded p-3 h-100">
              <div class="fw-semibold">{{ parcelle.nom ?: 'Parcelle #' ~ parcelle.id }}</div>
              <div class="text-muted small">{{ parcelle.localisation ?: 'Sans localisation' }}</div>
              <div class="mt-2">{{ (available_surface_map[parcelle.id] ?? 0)|number_format(0, '.', ' ') }} m&sup2; disponibles</div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <button class="btn btn-success">{{ submit_label|default('Enregistrer') }}</button>
    <a href="{{ path('app_culture_index') }}" class="btn btn-outline-secondary">Retour a la liste</a>
  </div>

  {% set parcelle_name_map = {} %}
  {% for parcelle in parcelles %}
    {% set parcelle_name_map = parcelle_name_map|merge({ (parcelle.id): (parcelle.nom ?: 'Parcelle #' ~ parcelle.id) }) %}
  {% endfor %}

  <div
    id="culture-form-data"
    data-surface-map="{{ available_surface_map|default({})|json_encode|e('html_attr') }}"
    data-yield-coefficients="{{ yield_coefficients|default({})|json_encode|e('html_attr') }}"
    data-parcelle-names="{{ parcelle_name_map|json_encode|e('html_attr') }}"
    hidden
  ></div>
{{ form_end(form) }}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const parcelleSelect = document.getElementById('{{ form.parcelleId.vars.id }}');
    const typeCultureInput = document.getElementById('{{ form.typeCulture.vars.id }}');
    const superficieInput = document.getElementById('{{ form.superficie.vars.id }}');
    const recolteEstimeInput = document.getElementById('{{ form.recolteEstime.vars.id }}');
    const surfaceAlert = document.getElementById('culture-surface-alert');
    const formDataNode = document.getElementById('culture-form-data');

    const parseJsonDataset = function (value, fallback) {
      if (!value) {
        return fallback;
      }

      try {
        const parsedValue = JSON.parse(value);

        if (parsedValue && typeof parsedValue === 'object') {
          return parsedValue;
        }
      } catch (error) {
        // Fallback to a safe default when data attributes cannot be parsed.
      }

      return fallback;
    };

    const surfaceMap = parseJsonDataset(formDataNode ? formDataNode.dataset.surfaceMap : '', {});
    const yieldCoefficients = parseJsonDataset(formDataNode ? formDataNode.dataset.yieldCoefficients : '', {});
    const parcelleNames = parseJsonDataset(formDataNode ? formDataNode.dataset.parcelleNames : '', {});

    const updateAvailableSurface = function () {
      if (!parcelleSelect || !surfaceAlert) {
        return;
      }

      const parcelleId = parcelleSelect.value;

      if (!parcelleId || typeof surfaceMap[parcelleId] === 'undefined') {
        surfaceAlert.className = 'alert alert-secondary';
        surfaceAlert.innerHTML = 'Selectionnez une parcelle. Les surfaces disponibles actuelles sont rappelees ci-dessous.';
        return;
      }

      surfaceAlert.className = 'alert alert-info';
      surfaceAlert.innerHTML = 'Surface disponible pour <strong id="selected-parcelle-name"></strong>: <span id="selected-available-surface"></span> m&sup2;';
      document.getElementById('selected-parcelle-name').textContent = parcelleNames[parcelleId] || ('Parcelle #' + parcelleId);
      document.getElementById('selected-available-surface').textContent = new Intl.NumberFormat('fr-FR', {
        maximumFractionDigits: 0,
      }).format(Number(surfaceMap[parcelleId]) || 0);
    };

    if (parcelleSelect && surfaceAlert) {
      parcelleSelect.addEventListener('change', updateAvailableSurface);
      updateAvailableSurface();
    }

    const updateEstimatedYieldPreview = function () {
      if (!typeCultureInput || !superficieInput || !recolteEstimeInput) {
        return;
      }

      const typeCulture = String(typeCultureInput.value || '').trim().toUpperCase();
      const superficie = parseFloat(String(superficieInput.value || '').replace(',', '.'));

      if (!typeCulture || Number.isNaN(superficie) || superficie <= 0) {
        recolteEstimeInput.value = '';
        return;
      }

      const coefficient = typeof yieldCoefficients[typeCulture] !== 'undefined'
        ? Number(yieldCoefficients[typeCulture])
        : Number(yieldCoefficients.AUTRE || 1);
      const estimate = Math.round(coefficient * superficie * 100) / 100;

      recolteEstimeInput.value = estimate.toFixed(2);
    };

    if (typeCultureInput && superficieInput && recolteEstimeInput) {
      typeCultureInput.addEventListener('change', updateEstimatedYieldPreview);
      superficieInput.addEventListener('input', updateEstimatedYieldPreview);
      updateEstimatedYieldPreview();
    }
  });
</script>
