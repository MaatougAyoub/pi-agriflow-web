{% extends 'parcelle_culture/layout.html.twig' %}

{% block page_title %}Mes cultures{% endblock %}
{% block hero_title %}Mes cultures{% endblock %}
{% block hero_subtitle %}Consultez et suivez l’ensemble de vos cultures{% endblock %}
{% block top_right_action %}
  <div class="d-flex gap-2 flex-wrap">
    <a href="{{ path('app_parcelle_index') }}" class="btn btn-outline-success">
      <i class="bi bi-grid me-2"></i>Voir mes parcelles
    </a>
    <a href="{{ path('app_culture_new') }}" class="btn btn-success">
      <i class="bi bi-plus-circle me-2"></i>Ajouter une culture
    </a>
  </div>
{% endblock %}

{% block module_body %}
  <form method="get" class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label for="search" class="form-label">Recherche par nom</label>
          <input type="text" id="search" name="search" class="form-control" value="{{ filters.search }}" placeholder="Nom de culture">
        </div>
        <div class="col-md-2">
          <label for="type_culture" class="form-label">Type de culture</label>
          <select id="type_culture" name="type_culture" class="form-select">
            <option value="">Tous</option>
            {% for typeCulture in type_culture_choices %}
              <option value="{{ typeCulture }}" {{ filters.type_culture == typeCulture ? 'selected' : '' }}>{{ typeCulture }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-2">
          <label for="parcelle_id" class="form-label">Parcelle</label>
          <select id="parcelle_id" name="parcelle_id" class="form-select">
            <option value="">Toutes</option>
            {% for parcelle in parcelles %}
              <option value="{{ parcelle.id }}" {{ filters.parcelle_id == (parcelle.id ~ '') ? 'selected' : '' }}>{{ parcelle.nom ?: 'Parcelle #' ~ parcelle.id }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-2">
          <label for="etat" class="form-label">Etat</label>
          <select id="etat" name="etat" class="form-select">
            <option value="">Tous</option>
            {% for etat in etat_choices %}
              <option value="{{ etat }}" {{ filters.etat == etat ? 'selected' : '' }}>{{ etat }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-1">
          <label for="sort" class="form-label">Tri</label>
          <select id="sort" name="sort" class="form-select">
            {% for sortKey, sortLabel in sort_choices %}
              <option value="{{ sortKey }}" {{ filters.sort == sortKey ? 'selected' : '' }}>{{ sortLabel }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="col-md-1">
          <label for="direction" class="form-label">Ordre</label>
          <select id="direction" name="direction" class="form-select">
            <option value="asc" {{ filters.direction == 'asc' ? 'selected' : '' }}>Asc</option>
            <option value="desc" {{ filters.direction == 'desc' ? 'selected' : '' }}>Desc</option>
          </select>
        </div>
        <div class="col-md-1 d-grid">
          <button class="btn btn-success">OK</button>
        </div>
      </div>
      <div class="d-flex justify-content-end mt-3">
        <a href="{{ path('app_culture_index') }}" class="btn btn-outline-secondary btn-sm">Reinitialiser</a>
      </div>
    </div>
  </form>

  {% if cultures is empty %}
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h3 class="h5">Aucune culture pour le moment</h3>
        <p class="mb-3">Aucun resultat ne correspond aux criteres actuels.</p>
        <a href="{{ path('app_culture_new') }}" class="btn btn-success">Creer une culture</a>
      </div>
    </div>
  {% else %}
    <div class="row g-4">
      {% for culture in cultures %}
        {% set parcelle = parcelles_by_id[culture.parcelleId] ?? null %}
        <div class="col-md-6 col-xl-4">
          <div class="card border-0 shadow-sm h-100 position-relative">
            <div class="card-body d-flex flex-column p-4">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <span class="badge text-bg-light">{{ culture.etat ?: 'Etat non renseigne' }}</span>
                <span class="badge text-bg-success">{{ culture.superficie|default(0)|number_format(0, '.', ' ') }} m&sup2;</span>
              </div>
              <h3 class="h5 mb-2">{{ culture.nom ?: 'Sans nom' }}</h3>
              <a href="{{ path('app_culture_show', {id: culture.id}) }}" class="stretched-link" aria-label="Voir la culture {{ culture.nom ?: culture.id }}"></a>
              <p class="text-muted mb-2">{{ parcelle ? (parcelle.nom ?: 'Parcelle #' ~ parcelle.id) : 'Parcelle introuvable' }}</p>
              <ul class="list-unstyled small text-muted mb-0">
                <li class="mb-2"><strong>Type de culture:</strong> {{ culture.typeCulture ?: 'Non renseigne' }}</li>
                <li><strong>Recolte estimee:</strong> {{ culture.recolteEstime is not null ? culture.recolteEstime|number_format(0, '.', ' ') ~ ' Kg' : 'Non renseignee' }}</li>
              </ul>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
