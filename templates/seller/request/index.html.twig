{% extends 'layouts/front.html.twig' %}

{% block page_title %}Demandes recues - AgriFlow{% endblock %}

{% block front_body %}
    <section class="section pt-5">
        <div class="container">
            <div class="row g-4 align-items-end mb-4">
                <div class="col-lg-8">
                    <h1 class="mb-2">Demandes recues</h1>
                    <p class="text-muted mb-0">Consultez les demandes envoyees sur vos annonces et repondez uniquement aux demandes en attente.</p>
                </div>
                <div class="col-lg-4">
                    <div class="agf-seller-toolbar justify-content-lg-end">
                        <a href="{{ path('app_seller_annonce_new') }}" class="btn btn-success">Ajouter une annonce</a>
                        <a href="{{ path('app_seller_annonce_index') }}" class="btn btn-outline-success">Mes annonces</a>
                    </div>
                </div>
            </div>

            <form method="get" class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-lg-8">
                            <label for="annonce" class="form-label">Filtrer par annonce</label>
                            <select id="annonce" name="annonce" class="form-select">
                                <option value="">Toutes mes annonces</option>
                                {% for annonce in annonces %}
                                    <option value="{{ annonce.id }}" {{ selectedAnnonce and selectedAnnonce.id == annonce.id ? 'selected' : '' }}>
                                        {{ annonce.titre }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-lg-4 d-flex gap-2">
                            <button class="btn btn-success">Filtrer</button>
                            <a href="{{ path('app_seller_request_index') }}" class="btn btn-outline-secondary">Reinitialiser</a>
                        </div>
                    </div>
                </div>
            </form>

            <div class="agf-seller-panel">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Annonce</th>
                                    <th>Client</th>
                                    <th>Periode</th>
                                    <th>Quantite</th>
                                    <th>Total</th>
                                    <th>Statut</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for reservation in reservations %}
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">{{ reservation.annonce.titre }}</div>
                                            <div class="small text-muted">{{ reservation.annonce.localisation }}</div>
                                        </td>
                                        <td>#{{ reservation.clientId }}</td>
                                        <td>{{ reservation.dateDebut|date('d/m/Y') }} - {{ reservation.dateFin|date('d/m/Y') }}</td>
                                        <td>{{ reservation.quantite }}</td>
                                        <td>{{ reservation.prixTotal }} TND</td>
                                        <td>{{ reservation.statut.label() }}</td>
                                        <td class="text-end">
                                            {% if reservation.statut.value == 'EN_ATTENTE' %}
                                                <div class="d-flex gap-2 justify-content-end flex-wrap">
                                                    <form method="post" action="{{ path('app_seller_request_accept', {id: reservation.id}) }}" class="agf-inline-form">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('accept-seller-reservation-' ~ reservation.id) }}">
                                                        <button class="btn btn-sm btn-success">Accepter</button>
                                                    </form>
                                                    <form method="post" action="{{ path('app_seller_request_refuse', {id: reservation.id}) }}" class="agf-inline-form">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('refuse-seller-reservation-' ~ reservation.id) }}">
                                                        <button class="btn btn-sm btn-outline-danger">Refuser</button>
                                                    </form>
                                                </div>
                                            {% else %}
                                                <span class="small text-muted">Lecture seule</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">
                                            Aucune demande recue pour le moment.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
