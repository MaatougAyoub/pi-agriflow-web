{% extends 'layouts/front.html.twig' %}

{% block page_title %}Mes annonces - AgriFlow{% endblock %}

{% block front_body %}
    <section class="section pt-5">
        <div class="container">
            <div class="row g-4 align-items-end mb-4">
                <div class="col-lg-8">
                    <h1 class="mb-2">Mon espace vendeur</h1>
                    <p class="text-muted mb-0">Publiez vos annonces, suivez les demandes recues et mettez a jour vos offres facilement.</p>
                </div>
                <div class="col-lg-4">
                    <div class="agf-seller-toolbar justify-content-lg-end">
                        <a href="{{ path('app_seller_request_index') }}" class="btn btn-outline-success">Demandes recues</a>
                        <a href="{{ path('app_seller_annonce_new') }}" class="btn btn-success">Ajouter une annonce</a>
                    </div>
                </div>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-lg-3 col-md-6">
                    <div class="agf-seller-stat">
                        <strong>{{ stats.annonces }}</strong>
                        <span>Annonce(s) publiee(s)</span>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="agf-seller-stat">
                        <strong>{{ stats.demandes }}</strong>
                        <span>Demande(s) recues</span>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="agf-seller-stat">
                        <strong>{{ stats.enAttente }}</strong>
                        <span>Demande(s) en attente</span>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="agf-seller-stat">
                        <strong>{{ stats.revenuEstime|number_format(2, '.', ' ') }} TND</strong>
                        <span>Revenu estime sur demandes acceptees</span>
                    </div>
                </div>
            </div>

            <div class="agf-kpi-strip mb-4">
                <span><strong>{{ stats.acceptees }}</strong> demande(s) acceptee(s)</span>
                <span><strong>{{ stats.enAttente }}</strong> encore a traiter</span>
                <span><strong>{{ stats.demandes }}</strong> demande(s) cumulee(s)</span>
            </div>

            <div class="alert alert-info border-0 shadow-sm mb-4" role="alert">
                Seules les annonces avec le statut <strong>Disponible</strong> apparaissent dans le marketplace public.
                Les annonces reservees, vendues ou louees restent consultables ici dans votre espace vendeur.
            </div>

            <div class="agf-seller-panel">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Titre</th>
                                    <th>Type</th>
                                    <th>Prix</th>
                                    <th>Stock</th>
                                    <th>Statut</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for annonce in annonces %}
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">{{ annonce.titre }}</div>
                                            <div class="small text-muted">{{ annonce.categorie }} - {{ annonce.localisation }}</div>
                                        </td>
                                        <td>{{ annonce.type.label() }}</td>
                                        <td>{{ annonce.prix }} TND / {{ annonce.unitePrix }}</td>
                                        <td>{{ annonce.quantiteDisponible }}</td>
                                        <td>{{ annonce.statut.label() }}</td>
                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                                <a href="{{ path('app_marketplace_show', {id: annonce.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                                <a href="{{ path('app_seller_request_index', {annonce: annonce.id}) }}" class="btn btn-sm btn-dark">Demandes</a>
                                                <a href="{{ path('app_seller_annonce_edit', {id: annonce.id}) }}" class="btn btn-sm btn-outline-success">Modifier</a>
                                                {{ include('seller/annonce/_delete_form.html.twig', {annonce: annonce}) }}
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            Vous n avez pas encore publie d annonce. Ajoutez votre premiere offre pour commencer.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="agf-pagination mt-4">
                {{ knp_pagination_render(annonces) }}
            </div>
        </div>
    </section>
{% endblock %}
