{% extends 'layouts/front.html.twig' %}

{% block page_title %}Nouvelle annonce - AgriFlow{% endblock %}

{% block front_body %}
    <section class="section pt-5">
        <div class="container">
            <div class="row g-4 align-items-end mb-4">
                <div class="col-lg-8">
                    <h1 class="mb-2">Publier une annonce</h1>
                    <p class="text-muted mb-0">Renseignez les informations principales de votre offre avant publication.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="{{ path('app_seller_annonce_index') }}" class="btn btn-outline-success">Retour a mes annonces</a>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-lg-5">
                    {{ include('seller/annonce/_form.html.twig', {form: form, button_label: 'Publier'}) }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
