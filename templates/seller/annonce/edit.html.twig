{% extends 'layouts/front.html.twig' %}

{% block page_title %}Modifier une annonce - AgriFlow{% endblock %}

{% block front_body %}
    <section class="section pt-5">
        <div class="container">
            <div class="row g-4 align-items-end mb-4">
                <div class="col-lg-8">
                    <h1 class="mb-2">Modifier mon annonce</h1>
                    <p class="text-muted mb-0">Mettez a jour les details de votre offre et gardez votre fiche a jour.</p>
                </div>
                <div class="col-lg-4">
                    <div class="agf-seller-toolbar justify-content-lg-end">
                        <a href="{{ path('app_seller_request_index', {annonce: annonce.id}) }}" class="btn btn-outline-secondary">Voir les demandes</a>
                        <a href="{{ path('app_seller_annonce_index') }}" class="btn btn-outline-success">Retour a mes annonces</a>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-lg-5">
                    {{ include('seller/annonce/_form.html.twig', {form: form, button_label: 'Mettre a jour'}) }}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
