{% extends 'layouts/front.html.twig' %}

{% block page_title %}Mes candidatures – AgriFlow{% endblock %}

{% block front_body %}
<section class="section">
    <div class="container" data-aos="fade-up">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Mes candidatures</h2>
                <p class="text-muted mb-0">{{ applications|length }} candidature{{ applications|length != 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('collab_index') }}" class="btn btn-outline-success">
                <i class="bi bi-search me-1"></i>Explorer les demandes
            </a>
        </div>

        {% include 'partials/_flash.html.twig' %}

        {% if applications|length == 0 %}
            <div class="text-center py-5">
                <i class="bi bi-file-earmark-person display-4 text-muted"></i>
                <p class="mt-3 text-muted">Vous n'avez pas encore postulé à une demande.</p>
                <a href="{{ path('collab_index') }}" class="btn btn-outline-success">Voir les collaborations ouvertes</a>
            </div>
        {% else %}
            <div class="row g-4">
                {% for app in applications %}
                    <div class="col-md-6 col-xl-4">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge
                                        {% if app.status == 'APPROVED' %}bg-success
                                        {% elseif app.status == 'REJECTED' %}bg-danger
                                        {% else %}bg-warning text-dark{% endif %}
                                    ">
                                        {% if app.status == 'APPROVED' %}
                                            <i class="bi bi-check-circle me-1"></i>Acceptée
                                        {% elseif app.status == 'REJECTED' %}
                                            <i class="bi bi-x-circle me-1"></i>Refusée
                                        {% else %}
                                            <i class="bi bi-clock me-1"></i>En attente
                                        {% endif %}
                                    </span>
                                    <small class="text-muted">{{ app.appliedAt|date('d/m/Y') }}</small>
                                </div>

                                {% if app.request %}
                                    <h5 class="fw-semibold mb-1">
                                        <a href="{{ path('collab_show', {id: app.request.id}) }}" class="text-decoration-none text-dark">
                                            {{ app.request.title }}
                                        </a>
                                    </h5>
                                    <p class="text-muted small mb-2">
                                        <i class="bi bi-geo-alt me-1 text-success"></i>{{ app.request.location }}
                                    </p>
                                {% endif %}

                                <hr class="my-2">

                                <div class="small text-muted">
                                    <div><i class="bi bi-briefcase me-1"></i>{{ app.yearsOfExperience }} ans d'expérience</div>
                                    <div><i class="bi bi-currency-exchange me-1"></i>{{ app.expectedSalaryAsFloat|number_format(2) }} DT attendu</div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock front_body %}
