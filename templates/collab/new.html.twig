{% extends 'layouts/front.html.twig' %}

{% block page_title %}Publier une demande – AgriFlow{% endblock %}

{% block front_body %}
<section class="section">
    <div class="container" data-aos="fade-up">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="fw-bold mb-1">Publier une demande de collaboration</h2>
                <p class="text-muted mb-4">Décrivez le type d'aide dont vous avez besoin pour votre exploitation.</p>

                {% include 'partials/_flash.html.twig' %}

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                        <div class="row g-3">
                            <div class="col-12">
                                {{ form_row(form.title) }}
                            </div>
                            <div class="col-12">
                                {{ form_row(form.description) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.location) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.neededPeople) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.startDate) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.endDate) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.salary) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.salaryPerDay) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.status) }}
                            </div>
                        </div>
                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-send me-1"></i>Publier
                            </button>
                            <a href="{{ path('collab_index') }}" class="btn btn-outline-secondary">Annuler</a>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock front_body %}
