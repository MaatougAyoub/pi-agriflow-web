{% extends 'layouts/front.html.twig' %}

{% block page_title %}Explorer les collaborations – AgriFlow{% endblock %}

{% block front_body %}
<section class="section">
    <div class="container" data-aos="fade-up">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1">Collaborations agricoles</h2>
                <p class="text-muted mb-0">{{ total }} demande{{ total != 1 ? 's' : '' }} ouverte{{ total != 1 ? 's' : '' }}</p>
            </div>
            {% if app.user %}
                <a href="{{ path('collab_new') }}" class="btn btn-success">
                    <i class="bi bi-plus-lg me-1"></i>Publier une demande
                </a>
            {% endif %}
        </div>

        {% include 'partials/_flash.html.twig' %}

        {% if requests|length == 0 %}
            <div class="text-center py-5">
                <i class="bi bi-search display-4 text-muted"></i>
                <p class="mt-3 text-muted">Aucune demande ouverte pour le moment.</p>
                {% if app.user %}
                    <a href="{{ path('collab_new') }}" class="btn btn-outline-success">Soyez le premier à publier</a>
                {% endif %}
            </div>
        {% else %}
            <div class="row g-4">
                {% for req in requests %}
                    <div class="col-md-6 col-xl-4">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge bg-success-subtle text-success rounded-pill">
                                        <i class="bi bi-geo-alt me-1"></i>{{ req.location }}
                                    </span>
                                    <small class="text-muted">{{ req.createdAt|date('d/m/Y') }}</small>
                                </div>

                                <h5 class="card-title fw-semibold mb-2">{{ req.title }}</h5>
                                <p class="card-text text-muted flex-grow-1">
                                    {{ req.description|slice(0, 120) }}{% if req.description|length > 120 %}…{% endif %}
                                </p>

                                <hr class="my-2">

                                <div class="d-flex gap-3 text-muted small mb-3">
                                    <span><i class="bi bi-people me-1"></i>{{ req.neededPeople }} pers.</span>
                                    <span><i class="bi bi-calendar-range me-1"></i>{{ req.startDate|date('d/m') }}→{{ req.endDate|date('d/m/Y') }}</span>
                                    {% if req.salaryPerDayAsFloat > 0 %}
                                        <span><i class="bi bi-currency-exchange me-1"></i>{{ req.salaryPerDayAsFloat|number_format(0) }} DT/j</span>
                                    {% endif %}
                                </div>

                                <div class="d-flex gap-2">
                                    <a href="{{ path('collab_show', {id: req.id}) }}" class="btn btn-outline-success btn-sm flex-grow-1">
                                        Voir détail
                                    </a>
                                    {% if app.user %}
                                        <a href="{{ path('collab_apply', {id: req.id}) }}" class="btn btn-success btn-sm">
                                            Postuler
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Pagination #}
            {% if lastPage > 1 %}
                <nav class="mt-5 d-flex justify-content-center" aria-label="Pagination">
                    <ul class="pagination">
                        <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('collab_index', {page: page - 1}) }}">‹ Préc.</a>
                        </li>
                        {% for p in 1..lastPage %}
                            <li class="page-item {{ p == page ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('collab_index', {page: p}) }}">{{ p }}</a>
                            </li>
                        {% endfor %}
                        <li class="page-item {{ page >= lastPage ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('collab_index', {page: page + 1}) }}">Suiv. ›</a>
                        </li>
                    </ul>
                </nav>
            {% endif %}
        {% endif %}
    </div>
</section>
{% endblock %}
