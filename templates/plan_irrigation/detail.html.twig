{% extends 'layouts/front.html.twig' %}
{% block page_title %}Détail Plan{% endblock %}
{% block front_body %}
<section style="padding:40px 0;background:#F0F2F5;min-height:80vh">
<div class="container">

    <a href="{{ path('plan_index') }}" class="btn btn-outline-secondary mb-4" style="border-radius:20px">← Retour</a>

    <div style="background:linear-gradient(135deg,#1B4332,#2D6A4F);border-radius:14px;
                padding:30px 35px;color:white;margin-bottom:30px">
        <div style="font-size:24px;font-weight:800;margin-bottom:8px">{{ plan.nomCulture }}</div>
        <div style="opacity:0.85;font-size:14px">
            Volume : {{ plan.volumeEauPropose }} L &nbsp;|&nbsp;
            Date : {{ plan.dateDemande ? plan.dateDemande|date('d/m/Y') : '-' }} &nbsp;|&nbsp;
            <span style="background:rgba(255,255,255,0.2);padding:3px 10px;border-radius:20px">
                {{ plan.statut }}
            </span>
        </div>
    </div>

    <div style="background:white;border-radius:14px;padding:30px;box-shadow:0 2px 12px rgba(0,0,0,0.07)">
        <h3 style="color:#1B4332;margin-bottom:20px">📅 Planning Hebdomadaire</h3>

        {% if jourData is empty %}
        <div style="text-align:center;color:#95a5a6;padding:40px">
            ⏳ L expert n a pas encore rempli ce plan.
        </div>
        {% else %}
        <div style="overflow-x:auto">
        <table class="table">
            <thead>
                <tr style="background:#f8f9fa">
                    <th>Données</th>
                    {% for j in ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'] %}
                    <th style="text-align:center">{{ j }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% set joursKeys = ['LUN','MAR','MER','JEU','VEN','SAM','DIM'] %}
                <tr>
                    <td style="font-weight:700;color:#1B4332">💧 Eau (mm)</td>
                    {% for k in joursKeys %}
                    <td style="text-align:center">{{ jourData[k] is defined ? jourData[k].eauMm : '-' }}</td>
                    {% endfor %}
                </tr>
                <tr>
                    <td style="font-weight:700;color:#1B4332">⏱ Durée (min)</td>
                    {% for k in joursKeys %}
                    <td style="text-align:center">{{ jourData[k] is defined ? jourData[k].tempsMin : '-' }}</td>
                    {% endfor %}
                </tr>
                <tr>
                    <td style="font-weight:700;color:#1B4332">🌡 Temp (°C)</td>
                    {% for k in joursKeys %}
                    <td style="text-align:center">{{ jourData[k] is defined ? jourData[k].tempC : '-' }}</td>
                    {% endfor %}
                </tr>
                <tr>
                    <td style="font-weight:700;color:#1B4332">💦 Humidité (%)</td>
                    {% for k in joursKeys %}
                    <td style="text-align:center">{{ jourData[k] is defined ? jourData[k].humidite : '-' }}</td>
                    {% endfor %}
                </tr>
                <tr>
                    <td style="font-weight:700;color:#1B4332">🌧 Pluie (mm)</td>
                    {% for k in joursKeys %}
                    <td style="text-align:center">{{ jourData[k] is defined ? jourData[k].pluie : '-' }}</td>
                    {% endfor %}
                </tr>
            </tbody>
        </table>
        </div>
        {% endif %}
    </div>

</div>
</section>
{% endblock %}
