{% extends 'layouts/front.html.twig' %}
{% block page_title %}Nouveau plan{% endblock %}
{% block front_body %}
<section style="padding:40px 0;background:#F0F2F5;min-height:80vh">
<div class="container">
    <div class="card shadow-sm border-0 rounded-4 p-4" style="max-width:600px;margin:0 auto">
        <h3 style="color:#2D5A27;font-weight:700">💧 Nouveau plan d irrigation</h3>
        <form method="post" class="mt-4">
            <div class="mb-3">
                <label class="form-label fw-bold">Culture</label>
                <input type="text" name="nom_culture" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Volume eau proposé (L)</label>
                <input type="number" step="0.01" name="volume_eau_propose" class="form-control" required>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn" style="background:#2D5A27;color:white;border-radius:20px">Enregistrer</button>
                <a href="{{ path('plan_index') }}" class="btn btn-outline-secondary" style="border-radius:20px">Annuler</a>
            </div>
        </form>
    </div>
</div>
</section>
{% endblock %}
