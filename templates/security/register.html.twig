{% extends 'base.html.twig' %}

{% block title %}Inscription | AgriFlow{% endblock %}

{% block stylesheets %}
<style>
:root {
    --green-900:#1b5e20;
    --green-800:#2e7d32;
    --green-700:#43a047;
    --ink:#263238;
    --muted:#637381;
    --danger-bg:#ffebee;
    --danger:#c62828;
    --success-bg:#e8f5e9;
    --success:#1b5e20;
}

* { box-sizing:border-box; }

body {
    margin:0;
    min-height:100vh;
    font-family:"Segoe UI","Noto Sans",sans-serif;
    color:var(--ink);
    background:
        radial-gradient(1200px 600px at 90% -20%, rgba(255,213,79,0.18), transparent),
        linear-gradient(135deg, var(--green-900), var(--green-800), var(--green-700));
    padding:24px;
}

.register-shell {
    width:100%;
    max-width:1180px;
    margin:0 auto;
    background:#fff;
    border-radius:20px;
    overflow:hidden;
    box-shadow:0 30px 60px rgba(0,0,0,0.25);
    display:grid;
    grid-template-columns: 0.9fr 1.1fr;
}

.register-hero {
    background-image:
        linear-gradient(rgba(27,94,32,0.66), rgba(27,94,32,0.82)),
        url('https://images.unsplash.com/photo-1500595046743-cd271d694d30?auto=format&fit=crop&w=1200&q=80');
    background-size:cover;
    background-position:center;
    color:#fff;
    padding:40px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    gap:18px;
}

.brand-logo {
    width:220px;
    max-width:100%;
}

.brand-logo img {
    width:100%;
    height:auto;
    object-fit:contain;
    filter:drop-shadow(0 6px 12px rgba(0,0,0,0.35));
}

.brand-title {
    margin:0;
    font-size:52px;
    line-height:1;
    font-weight:800;
    text-shadow:0 2px 8px rgba(0,0,0,0.35);
}

.brand-sub {
    margin:0;
    font-size:18px;
    opacity:0.95;
}

.brand-divider {
    width:130px;
    height:3px;
    border-radius:999px;
    background:linear-gradient(90deg, transparent, #ffd54f, transparent);
}

.feature-list {
    margin:0;
    padding:0;
    list-style:none;
    display:grid;
    gap:10px;
    font-weight:600;
}

.register-form {
    padding:34px 38px;
}

.form-header {
    margin-bottom:20px;
}

.register-title {
    margin:0;
    font-size:34px;
    color:var(--green-900);
}

.register-subtitle {
    margin:8px 0 0;
    color:var(--muted);
}

.alert {
    border-radius:10px;
    padding:10px 12px;
    font-size:14px;
    margin-bottom:12px;
}

.alert-danger {
    background:var(--danger-bg);
    color:var(--danger);
}

.alert-success {
    background:var(--success-bg);
    color:var(--success);
}

.form-grid {
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap:16px;
}

.field {
    display:grid;
    gap:7px;
}

.field.full {
    grid-column:1 / -1;
}

.field label {
    font-weight:700;
    font-size:14px;
}

.field input,
.field select {
    width:100%;
    border:1.5px solid #dfe3e8;
    border-radius:10px;
    padding:12px;
    font-size:15px;
    outline:none;
}

.field input:focus,
.field select:focus {
    border-color:var(--green-700);
    box-shadow:0 0 0 4px rgba(67,160,71,0.16);
}

.section-box {
    margin-top:18px;
    padding:18px;
    border:1px solid #edf1f4;
    border-radius:14px;
    background:#fbfdfb;
}

.section-title {
    margin:0 0 14px;
    color:var(--green-900);
    font-size:18px;
}

.actions {
    margin-top:20px;
    display:flex;
    gap:12px;
    flex-wrap:wrap;
}

.btn {
    border:none;
    border-radius:10px;
    cursor:pointer;
    font-weight:700;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:46px;
    padding:0 18px;
}

.btn-primary {
    color:#fff;
    background:linear-gradient(90deg, var(--green-900), var(--green-800));
    box-shadow:0 8px 18px rgba(46,125,50,0.28);
}

.btn-secondary {
    border:1px solid #dfe3e8;
    color:#6e7a86;
    background:#fff;
}

.helper-row {
    margin-top:14px;
    text-align:center;
    font-size:13px;
    color:#66757f;
}

.helper-row a {
    color:var(--green-800);
    font-weight:700;
    text-decoration:none;
}

.role-box {
    display:flex;
    gap:12px;
    flex-wrap:wrap;
}

.role-chip {
    border:1px solid #dfe3e8;
    border-radius:999px;
    padding:10px 14px;
    cursor:pointer;
    background:#fff;
    user-select:none;
}

.role-chip input {
    margin-right:8px;
}

.role-section {
    display:none;
    margin-top:16px;
}

.role-section.is-visible {
    display:block;
}

@media (max-width: 1024px) {
    .register-shell {
        grid-template-columns:1fr;
        max-width:780px;
    }
}

@media (max-width: 720px) {
    .register-form {
        padding:24px;
    }

    .form-grid {
        grid-template-columns:1fr;
    }
}
</style>
{% endblock %}

{% block body %}
<main class="register-shell">
    <section class="register-hero">
        <div class="brand-logo">
            <img src="{{ asset('template/assets/img/logo2.png') }}" alt="AgriFlow">
        </div>
        <h1 class="brand-title">AgriFlow</h1>
        <p class="brand-sub">Inscription des utilisateurs de la plateforme</p>
        <div class="brand-divider"></div>
        <ul class="feature-list">
            <li>Compte expert ou agriculteur</li>
            <li>Signature image obligatoire</li>
            <li>Carte professionnelle pour agriculteur</li>
            <li>Certification pour expert</li>
        </ul>
    </section>

    <section class="register-form">
        <div class="form-header">
            <h2 class="register-title">S'inscrire</h2>
            <p class="register-subtitle">Remplissez le formulaire selon votre role.</p>
        </div>

        <div id="clientErrors"></div>

        {% for error in errors %}
            <div class="alert alert-danger">{{ error }}</div>
        {% endfor %}

        {% if success_message %}
            <div class="alert alert-success">{{ success_message }}</div>
        {% endif %}

        <form method="post" enctype="multipart/form-data" novalidate>
            <div class="form-grid">
                <div class="field full">
                    <label>Type d'utilisateur *</label>
                    <div class="role-box">
                        <label class="role-chip">
                            <input type="radio" name="role" value="AGRICULTEUR" {% if selected_role == 'AGRICULTEUR' %}checked{% endif %}>
                            Agriculteur
                        </label>
                        <label class="role-chip">
                            <input type="radio" name="role" value="EXPERT" {% if selected_role == 'EXPERT' %}checked{% endif %}>
                            Expert
                        </label>
<!--                         <label class="role-chip">
                            <input type="radio" name="role" value="ADMIN" {% if selected_role == 'ADMIN' %}checked{% endif %}>
                            Admin
                        </label> -->
                    </div>
                </div>

                <div class="field">
                    <label>Nom *</label>
                    <input type="text" name="nom" value="{{ old.nom }}" placeholder="Votre nom" required>
                </div>
                <div class="field">
                    <label>Prenom *</label>
                    <input type="text" name="prenom" value="{{ old.prenom }}" placeholder="Votre prenom" required>
                </div>
                <div class="field">
                    <label>CIN *</label>
                    <input type="text" name="cin" value="{{ old.cin }}" placeholder="Ex: 12345678" maxlength="8" inputmode="numeric" pattern="[0-9]{8}" title="Le CIN doit contenir 8 chiffres." required>
                </div>
                <div class="field">
                    <label>Email *</label>
                    <input type="email" name="email" value="{{ old.email }}" placeholder="exemple@email.com" required>
                </div>
                <div class="field">
                    <label>Mot de passe *</label>
                    <input type="password" name="password" placeholder="********" pattern="(?=.*[A-Z])(?=.*[0-9]).{7,}" title="Au moins 7 caracteres, un chiffre et une majuscule." required>
                </div>
                <div class="field">
                    <label>Confirmation mot de passe *</label>
                    <input type="password" name="password_confirm" placeholder="********" required>
                </div>
                <div class="field full">
                    <label>Signature *</label>
                    <input type="file" name="signature" accept="image/*" required>
                </div>
            </div>

            <div id="farmerSection" class="section-box role-section {% if selected_role == 'AGRICULTEUR' %}is-visible{% endif %}">
                <h3 class="section-title">Informations specifiques - Agriculteur</h3>
                <div class="form-grid">
                    <div class="field">
                        <label>Nom (arabe) *</label>
                        <input type="text" name="nom_ar" value="{{ old.nom_ar }}" placeholder="الاسم">
                    </div>
                    <div class="field">
                        <label>Prenom (arabe) *</label>
                        <input type="text" name="prenom_ar" value="{{ old.prenom_ar }}" placeholder="اللقب">
                    </div>
                    <div class="field full">
                        <label>Adresse *</label>
                        <input type="text" name="adresse" value="{{ old.adresse }}" placeholder="Votre adresse complete">
                    </div>
<!--                     <div class="field full">
                        <label>Parcelles</label>
                        <input type="text" name="parcelles" value="{{ old.parcelles }}" placeholder="Informations sur vos parcelles">
                    </div> -->
                    <div class="field full">
                        <label>Carte professionnelle *</label>
                        <input type="file" name="carte_pro" accept="image/*">
                    </div>
                </div>
            </div>

            <div id="expertSection" class="section-box role-section {% if selected_role == 'EXPERT' %}is-visible{% endif %}">
                <h3 class="section-title">Informations specifiques - Expert</h3>
                <div class="form-grid">
                    <div class="field full">
                        <label>Certification *</label>
                        <input type="file" name="certification" accept="image/*">
                    </div>
                </div>
            </div>

            <div class="actions">
                <button class="btn btn-primary" type="submit">S'inscrire</button>
                <a class="btn btn-secondary" href="{{ path('site_home') }}">Annuler</a>
            </div>
        </form>

        <div class="helper-row">
            Vous avez deja un compte ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>
    </section>
</main>

<script>
(function () {
    const form = document.querySelector('form[method="post"]');
    const clientErrors = document.getElementById('clientErrors');
    const roleInputs = document.querySelectorAll('input[name="role"]');
    const farmerSection = document.getElementById('farmerSection');
    const expertSection = document.getElementById('expertSection');
    const nomInput = document.querySelector('input[name="nom"]');
    const prenomInput = document.querySelector('input[name="prenom"]');
    const cinInput = document.querySelector('input[name="cin"]');
    const emailInput = document.querySelector('input[name="email"]');
    const passwordInput = document.querySelector('input[name="password"]');
    const passwordConfirmInput = document.querySelector('input[name="password_confirm"]');
    const signatureInput = document.querySelector('input[name="signature"]');
    const nomArInput = document.querySelector('input[name="nom_ar"]');
    const prenomArInput = document.querySelector('input[name="prenom_ar"]');
    const adresseInput = document.querySelector('input[name="adresse"]');
    const carteProInput = document.querySelector('input[name="carte_pro"]');
    const certificationInput = document.querySelector('input[name="certification"]');

    function setRequired(input, required) {
        if (input) {
            input.required = required;
        }
    }

    function renderClientError(message) {
        if (!clientErrors) {
            return;
        }

        clientErrors.innerHTML = '';
        if (!message) {
            return;
        }

        const errorBox = document.createElement('div');
        errorBox.className = 'alert alert-danger';
        errorBox.textContent = message;
        clientErrors.appendChild(errorBox);
    }

    function getSelectedRole() {
        const selected = document.querySelector('input[name="role"]:checked');

        return selected ? selected.value : 'AGRICULTEUR';
    }

    function getFirstValidationError() {
        const role = getSelectedRole();
        const cinValue = (cinInput ? cinInput.value : '').trim();
        const emailValue = (emailInput ? emailInput.value : '').trim();
        const passwordValue = passwordInput ? passwordInput.value : '';
        const passwordConfirmValue = passwordConfirmInput ? passwordConfirmInput.value : '';

        if (!nomInput || nomInput.value.trim() === '') {
            return 'Veuillez entrer votre nom.';
        }
        if (!prenomInput || prenomInput.value.trim() === '') {
            return 'Veuillez entrer votre prenom.';
        }
        if (!/^\d{8}$/.test(cinValue)) {
            return 'Veuillez entrer un CIN valide (8 chiffres).';
        }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailValue)) {
            return 'Veuillez entrer un email valide.';
        }
        if (!/^(?=.*[A-Z])(?=.*\d).{7,}$/.test(passwordValue)) {
            return 'Veuillez entrer un mot de passe avec au moins 7 caracteres, un chiffre et une lettre majuscule.';
        }
        if (passwordValue !== passwordConfirmValue) {
            return 'Les mots de passe ne correspondent pas.';
        }
        if (!signatureInput || signatureInput.files.length === 0) {
            return 'Veuillez ajouter votre signature.';
        }

        if (role === 'AGRICULTEUR') {
            if (!nomArInput || nomArInput.value.trim() === '') {
                return 'Veuillez entrer le nom arabe (agriculteur).';
            }
            if (!prenomArInput || prenomArInput.value.trim() === '') {
                return 'Veuillez entrer le prenom arabe (agriculteur).';
            }
            if (!adresseInput || adresseInput.value.trim() === '') {
                return 'Veuillez entrer l\'adresse (agriculteur).';
            }
            if (!carteProInput || carteProInput.files.length === 0) {
                return 'Veuillez ajouter la carte professionnelle (agriculteur).';
            }
        }

        if (role === 'EXPERT' && (!certificationInput || certificationInput.files.length === 0)) {
            return 'Veuillez ajouter la certification (expert).';
        }

        return null;
    }

    function toggleSections() {
        const value = getSelectedRole();
        const isFarmer = value === 'AGRICULTEUR';
        const isExpert = value === 'EXPERT';

        farmerSection.classList.toggle('is-visible', isFarmer);
        expertSection.classList.toggle('is-visible', isExpert);
        setRequired(nomArInput, isFarmer);
        setRequired(prenomArInput, isFarmer);
        setRequired(adresseInput, isFarmer);
        setRequired(carteProInput, isFarmer);
        setRequired(certificationInput, isExpert);
        renderClientError(null);
    }

    if (form) {
        form.addEventListener('submit', function (event) {
            const validationError = getFirstValidationError();

            if (validationError) {
                event.preventDefault();
                renderClientError(validationError);
            }
        });
    }

    roleInputs.forEach(input => input.addEventListener('change', toggleSections));
    toggleSections();
})();
</script>
{% endblock %}
