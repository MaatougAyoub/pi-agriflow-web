{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublie | AgriFlow{% endblock %}

{% block body_class %}agf-auth-page{% endblock %}

{% block stylesheets %}
<style data-turbo-temporary>
.agf-auth-page {
    --green-900:#1b5e20;
    --green-800:#2e7d32;
    --green-700:#43a047;
    --ink:#263238;
    --muted:#637381;
    --danger-bg:#ffebee;
    --danger:#c62828;
    --success-bg:#e8f5e9;
    --success:#1b5e20;

    margin:0;
    min-height:100vh;
    font-family:"Segoe UI","Noto Sans",sans-serif;
    color:var(--ink);
    background:
        radial-gradient(1200px 600px at 90% -20%, rgba(255,213,79,0.2),transparent),
        linear-gradient(135deg,var(--green-900),var(--green-800),var(--green-700));
    display:grid;
    place-items:center;
    padding:24px;
}

.agf-auth-page * {
    box-sizing:border-box;
}

.agf-auth-page .reset-shell {
    width:100%;
    max-width:620px;
    background:#fff;
    border-radius:20px;
    padding:34px;
    box-shadow:0 30px 60px rgba(0,0,0,0.25);
}

.agf-auth-page .reset-title {
    margin:0;
    font-size:34px;
    color:var(--green-900);
}

.agf-auth-page .reset-subtitle {
    margin:10px 0 20px;
    color:var(--muted);
}

.agf-auth-page .alert {
    border-radius:10px;
    padding:10px 12px;
    font-size:14px;
    margin-bottom:12px;
}

.agf-auth-page .alert-danger {
    background:var(--danger-bg);
    color:var(--danger);
}

.agf-auth-page .alert-success {
    background:var(--success-bg);
    color:var(--success);
}

.agf-auth-page .field {
    display:grid;
    gap:7px;
    margin-bottom:12px;
}

.agf-auth-page .field label {
    font-weight:700;
}

.agf-auth-page .field input {
    border:1.5px solid #dfe3e8;
    border-radius:10px;
    padding:12px;
}

.agf-auth-page .field input:focus {
    border-color:var(--green-700);
    box-shadow:0 0 0 4px rgba(67,160,71,0.16);
}

.agf-auth-page .field input[readonly] {
    background:#f6f8f9;
    color:#5d6973;
}

.agf-auth-page .btn-row {
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    margin-top:10px;
}

.agf-auth-page .btn {
    border:none;
    border-radius:10px;
    cursor:pointer;
    font-weight:700;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:44px;
    padding:0 16px;
}

.agf-auth-page .btn-primary {
    color:#fff;
    background:linear-gradient(90deg,var(--green-900),var(--green-800));
}

.agf-auth-page .btn-secondary {
    border:1px solid #dfe3e8;
    color:#5e6a73;
    background:#fff;
}

@media(max-width:640px){
    .agf-auth-page .reset-shell {
        padding:24px;
    }
}
</style>
{% endblock %}

{% block body %}
<main class="reset-shell">
    <h1 class="reset-title">Mot de passe oublie ?</h1>
    <p class="reset-subtitle">Saisissez votre email. S'il existe dans la base, vous pourrez choisir un nouveau mot de passe.</p>

    {% if email_error %}
        <div class="alert alert-danger">{{ email_error }}</div>
    {% endif %}

    {% if password_error %}
        <div class="alert alert-danger">{{ password_error }}</div>
    {% endif %}

    {% if show_reset_form %}
        <div class="alert alert-success">Email verifie. Apres validation, un code de verification a 6 chiffres sera genere.</div>

        <form method="post" data-turbo="false" novalidate>
            <input type="hidden" name="step" value="reset">
            <input type="hidden" name="verified_email" value="{{ verified_email }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot-password-reset') }}">

            <div class="field">
                <label>Email</label>
                <input type="email" value="{{ verified_email }}" readonly>
            </div>

            <div class="field">
                <label>Nouveau mot de passe</label>
                <input type="password" name="new_password" pattern="(?=.*[A-Z])(?=.*[0-9]).{7,}" title="Au moins 7 caracteres, un chiffre et une majuscule." required>
            </div>

            <div class="field">
                <label>Confirmer le mot de passe</label>
                <input type="password" name="confirm_password" required>
            </div>

            <div class="btn-row">
                <button class="btn btn-primary" type="submit">Continuer</button>
                <a class="btn btn-secondary" href="{{ path('app_login') }}">Retour connexion</a>
            </div>
        </form>
    {% else %}
        <form method="post" data-turbo="false" novalidate>
            <input type="hidden" name="step" value="email">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot-password-email') }}">

            <div class="field">
                <label>Email</label>
                <input type="email" name="email" value="{{ email }}" placeholder="exemple@email.com" required>
            </div>

            <div class="btn-row">
                <button class="btn btn-primary" type="submit">Verifier l'email</button>
                <a class="btn btn-secondary" href="{{ path('app_login') }}">Retour connexion</a>
            </div>
        </form>
    {% endif %}
</main>
{% endblock %}
