{% extends 'base.html.twig' %}

{% block title %}Verification | AgriFlow{% endblock %}

{% block stylesheets %}
<style data-turbo-temporary>
:root {
    --green-900:#1b5e20;
    --green-800:#2e7d32;
    --ink:#263238;
    --muted:#637381;
    --danger-bg:#ffebee;
    --danger:#c62828;
}

* { box-sizing:border-box; }

body {
    margin:0;
    min-height:100vh;
    font-family:"Segoe UI","Noto Sans",sans-serif;
    color:var(--ink);
    background:
        radial-gradient(1200px 600px at 90% -20%, rgba(255,213,79,0.18), transparent),
        linear-gradient(135deg, var(--green-900), var(--green-800));
    padding:24px;
}

.verify-shell {
    max-width:560px;
    margin:0 auto;
    background:#fff;
    border-radius:18px;
    padding:32px 34px;
    box-shadow:0 30px 60px rgba(0,0,0,0.25);
}

.verify-title {
    margin:0 0 8px;
    font-size:28px;
    color:var(--green-900);
}

.verify-subtitle {
    margin:0 0 18px;
    color:var(--muted);
}

.alert {
    border-radius:10px;
    padding:10px 12px;
    font-size:14px;
    margin-bottom:12px;
}

.alert-danger {
    background:var(--danger-bg);
    color:var(--danger);
}

.field {
    display:grid;
    gap:7px;
    margin-bottom:16px;
}

.field label {
    font-weight:700;
    font-size:14px;
}

.field input {
    width:100%;
    border:1.5px solid #dfe3e8;
    border-radius:10px;
    padding:12px;
    font-size:15px;
    outline:none;
}

.field input:focus {
    border-color:var(--green-800);
    box-shadow:0 0 0 4px rgba(46,125,50,0.16);
}

.actions {
    display:flex;
    gap:12px;
    flex-wrap:wrap;
}

.btn {
    border:none;
    border-radius:10px;
    cursor:pointer;
    font-weight:700;
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:46px;
    padding:0 18px;
}

.btn-primary {
    color:#fff;
    background:linear-gradient(90deg, var(--green-900), var(--green-800));
    box-shadow:0 8px 18px rgba(46,125,50,0.28);
}

.btn-secondary {
    border:1px solid #dfe3e8;
    color:#6e7a86;
    background:#fff;
}
</style>
{% endblock %}

{% block body %}
<main class="verify-shell">
    <h1 class="verify-title">Verification du code</h1>
    <p class="verify-subtitle">
        Un code a 6 chiffres a ete genere. Consultez le terminal et collez-le ici.
    </p>

    {% if email %}
        <p class="verify-subtitle">Email: {{ email }}</p>
    {% endif %}

    {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
    {% endif %}

    <form method="post">
        <div class="field">
            <label>Code de verification *</label>
            <input type="text" name="verification_code" maxlength="6" inputmode="numeric" pattern="[0-9]{6}" required>
        </div>
        <div class="actions">
            <button class="btn btn-primary" type="submit">Valider</button>
            <a class="btn btn-secondary" href="{{ path('app_register') }}">Retour</a>
        </div>
    </form>
</main>
{% endblock %}
