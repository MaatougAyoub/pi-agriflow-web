{% extends 'admin/layout.html.twig' %}

{% block admin_title %}Dashboard admin{% endblock %}
{% block admin_page_title %}Dashboard{% endblock %}
{% block admin_page_subtitle %}Vue d'ensemble simple pour consulter et moderer les parcelles et les cultures.{% endblock %}

{% block admin_body %}
  <div class="row g-4">
    <div class="col-md-6">
      <div class="card admin-card h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <div class="text-muted small mb-1">Parcelles</div>
              <h2 class="h1 mb-0">{{ parcelle_count }}</h2>
            </div>
            <i class="bi bi-grid fs-1 text-success"></i>
          </div>
          <p class="text-muted">Consultez toutes les parcelles, filtrez la liste et accedez aux details.</p>
          <a href="{{ path('app_admin_parcelle_index') }}" class="btn btn-success">Voir les parcelles</a>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card admin-card h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <div class="text-muted small mb-1">Cultures</div>
              <h2 class="h1 mb-0">{{ culture_count }}</h2>
            </div>
            <i class="bi bi-flower1 fs-1 text-success"></i>
          </div>
          <p class="text-muted">Consultez toutes les cultures, filtrez la liste et ouvrez les fiches detail.</p>
          <a href="{{ path('app_admin_culture_index') }}" class="btn btn-success">Voir les cultures</a>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
