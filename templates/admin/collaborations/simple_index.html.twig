{% extends 'layouts/admin.html.twig' %}

{% block page_title %}Gestion des collaborations - Simple{% endblock %}
{% block admin_title %}Collaborations{% endblock %}
{% block admin_subtitle %}Vue simplifiée pour diagnostic{% endblock %}

{% block admin_body %}
<section class="section">
    <div class="container">

        {# Header #}
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-1"><i class="bi bi-shield-check me-2 text-success"></i>Gestion des collaborations</h2>
                <p class="text-muted mb-0">Vue simplifiée - {{ totalRequests }} demande(s) trouvée(s)</p>
            </div>
            <a href="{{ path('app_admin_collab_index') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Retour admin normal
            </a>
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {# Tableau des demandes #}
        {% if requests|length == 0 %}
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="text-muted mt-3">Aucune demande trouvée</h4>
                <p class="text-muted">Vérifiez la base de données ou les filtres appliqués.</p>
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle bg-white shadow-sm">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Titre</th>
                            <th>Publié par</th>
                            <th>Lieu</th>
                            <th>Statut</th>
                            <th>Candidatures</th>
                            <th>Créé le</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for req in requests %}
                        <tr>
                            <td class="text-muted">{{ req.id }}</td>
                            <td class="fw-bold">{{ req.title }}</td>
                            <td>{{ req.publisher ?? '—' }}</td>
                            <td>{{ req.location }}</td>
                            <td>
                                {% if req.status == 'APPROVED' %}
                                    <span class="badge bg-success">Approuvée</span>
                                {% elseif req.status == 'PENDING' %}
                                    <span class="badge bg-warning text-dark">En attente</span>
                                {% elseif req.status == 'REJECTED' %}
                                    <span class="badge bg-danger">Refusée</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ req.status }}</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% set count = applicationCounts[req.id] ?? 0 %}
                                <span class="badge bg-{{ count > 0 ? 'primary' : 'secondary' }}">{{ count }}</span>
                            </td>
                            <td>{{ req.createdAt ? req.createdAt|date('d/m/Y H:i') : '—' }}</td>
                            <td>
                                <div class="d-flex gap-1">
                                    {% if req.status != 'APPROVED' %}
                                        <form method="post" action="{{ path('app_admin_collab_simple_approve', {id: req.id}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('approve_' ~ req.id) }}">
                                            <button type="submit" class="btn btn-sm btn-success" title="Approuver">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                    {% if req.status != 'REJECTED' %}
                                        <form method="post" action="{{ path('app_admin_collab_simple_reject', {id: req.id}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject_' ~ req.id) }}">
                                            <button type="submit" class="btn btn-sm btn-danger" title="Rejeter">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}

    </div>
</section>
{% endblock %}
