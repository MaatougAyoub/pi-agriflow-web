{% extends 'admin/layout.html.twig' %}

{% block admin_title %}Admin cultures{% endblock %}
{% block admin_page_title %}Cultures{% endblock %}
{% block admin_page_subtitle %}Consultez toutes les cultures, filtrez les resultats et ouvrez les details.{% endblock %}

{% block admin_body %}
  <div class="card admin-card mb-4">
    <div class="card-body p-4">
      <form method="get">
        <div class="row g-3 align-items-end">
          <div class="col-md-3">
            <label for="search" class="form-label">Recherche par nom</label>
            <input type="text" id="search" name="search" class="form-control" value="{{ filters.search }}" placeholder="Nom de culture">
          </div>
          <div class="col-md-2">
            <label for="type_culture" class="form-label">Type de culture</label>
            <select id="type_culture" name="type_culture" class="form-select">
              <option value="">Tous</option>
              {% for typeCulture in type_culture_choices %}
                <option value="{{ typeCulture }}" {{ filters.type_culture == typeCulture ? 'selected' : '' }}>{{ typeCulture }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="col-md-2">
            <label for="parcelle_id" class="form-label">Parcelle</label>
            <select id="parcelle_id" name="parcelle_id" class="form-select">
              <option value="">Toutes</option>
              {% for parcelle in parcelles %}
                <option value="{{ parcelle.id }}" {{ filters.parcelle_id == (parcelle.id ~ '') ? 'selected' : '' }}>
                  {{ parcelle.nom ?: 'Parcelle #' ~ parcelle.id }}
                </option>
              {% endfor %}
            </select>
          </div>
          <div class="col-md-2">
            <label for="etat" class="form-label">Etat</label>
            <select id="etat" name="etat" class="form-select">
              <option value="">Tous</option>
              {% for etat in etat_choices %}
                <option value="{{ etat }}" {{ filters.etat == etat ? 'selected' : '' }}>{{ etat }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="col-md-1">
            <label for="sort" class="form-label">Tri</label>
            <select id="sort" name="sort" class="form-select">
              {% for sortKey, sortLabel in sort_choices %}
                <option value="{{ sortKey }}" {{ filters.sort == sortKey ? 'selected' : '' }}>{{ sortLabel }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="col-md-1">
            <label for="direction" class="form-label">Ordre</label>
            <select id="direction" name="direction" class="form-select">
              <option value="asc" {{ filters.direction == 'asc' ? 'selected' : '' }}>Asc</option>
              <option value="desc" {{ filters.direction == 'desc' ? 'selected' : '' }}>Desc</option>
            </select>
          </div>
          <div class="col-md-1 d-grid">
            <button class="btn btn-success">Filtrer</button>
          </div>
        </div>
      </form>

      <div class="d-flex justify-content-end mt-3">
        <a href="{{ path('app_admin_culture_index') }}" class="btn btn-outline-secondary btn-sm">Reinitialiser</a>
      </div>
    </div>
  </div>

  <div class="card admin-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table admin-table mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Nom</th>
              <th>Parcelle ID</th>
              <th>Proprietaire ID</th>
              <th>Type culture</th>
              <th>Superficie</th>
              <th>Etat</th>
              <th>Recolte estimee</th>
              <th>Date de creation</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for culture in cultures %}
              <tr>
                <td>{{ culture.id }}</td>
                <td>{{ culture.nom ?: 'Sans nom' }}</td>
                <td>
                  {% set parcelle = parcelles_by_id[culture.parcelleId] ?? null %}
                  {% if parcelle %}
                    <a href="{{ path('app_admin_parcelle_show', {id: parcelle.id}) }}" class="text-decoration-none">{{ parcelle.id }}</a>
                  {% else %}
                    {{ culture.parcelleId ?: '-' }}
                  {% endif %}
                </td>
                <td>{{ culture.proprietaireId ?: '-' }}</td>
                <td>{{ culture.typeCulture ?: '-' }}</td>
                <td>{{ culture.superficie|default(0)|number_format(0, '.', ' ') }} m&sup2;</td>
                <td>{{ culture.etat ?: '-' }}</td>
                <td>{{ culture.recolteEstime is not null ? culture.recolteEstime|number_format(0, '.', ' ') ~ ' Kg' : '-' }}</td>
                <td>{{ culture.dateCreation ? culture.dateCreation|date('d/m/Y H:i') : '-' }}</td>
                <td class="admin-actions">
                  <a href="{{ path('app_admin_culture_show', {id: culture.id}) }}" class="btn btn-outline-secondary btn-sm">Voir</a>
                  {% include 'admin/culture/_delete_form.html.twig' with {culture: culture} %}
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="10" class="text-center py-4 text-muted">Aucune culture ne correspond aux criteres actuels.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{% endblock %}
