{% extends 'layouts/admin.html.twig' %}

{% block admin_title %}Gestion des reservations{% endblock %}
{% block admin_subtitle %}Suivi des demandes clients et des montants enregistres{% endblock %}

{% block admin_body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div></div>
        <a href="{{ path('app_admin_reservation_new') }}" class="btn btn-success">Ajouter une reservation</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Annonce</th>
                            <th>Client</th>
                            <th>Periode</th>
                            <th>Commission</th>
                            <th>Total</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for reservation in reservations %}
                            <tr>
                                <td>
                                    <div class="fw-semibold">{{ reservation.annonce.titre }}</div>
                                    <div class="small text-muted">{{ reservation.annonce.localisationNormalisee ?: reservation.annonce.localisation }}</div>
                                </td>
                                <td>#{{ reservation.clientId }}</td>
                                <td>
                                    {% if reservation.annonce.isLocation() %}
                                        {{ reservation.dateDebut|date('d/m/Y') }} - {{ reservation.dateFin|date('d/m/Y') }}
                                    {% else %}
                                        Vente ponctuelle
                                    {% endif %}
                                </td>
                                <td>{{ reservation.commission }} TND</td>
                                <td>{{ reservation.prixTotal }} TND</td>
                                <td>{{ reservation.statut.label() }}</td>
                                <td class="text-end">
                                    <a href="{{ path('app_admin_reservation_quote', {id: reservation.id}) }}" class="btn btn-sm btn-outline-secondary">Devis PDF</a>
                                    <a href="{{ path('app_admin_reservation_edit', {id: reservation.id}) }}" class="btn btn-sm btn-outline-success">Modifier</a>
                                    {{ include('admin/reservation/_delete_form.html.twig', {reservation: reservation}) }}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">Aucune reservation pour le moment.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="agf-pagination mt-4">
        {{ knp_pagination_render(reservations) }}
    </div>
{% endblock %}
