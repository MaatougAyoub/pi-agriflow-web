{% extends 'base.html.twig' %}

{% block title %}{% block admin_title %}Admin{% endblock %} | AgriFlow{% endblock %}

{% block stylesheets %}
  <link href="{{ asset('template/assets/img/favicon.png') }}" rel="icon">
  <link href="{{ asset('template/assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
  <link href="{{ asset('template/assets/vendor/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">
  <link href="{{ asset('template/assets/css/main.css') }}" rel="stylesheet">

  <style>
    body {
      background: #f4f6f1;
    }

    .admin-shell {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 260px 1fr;
    }

    .admin-sidebar {
      background: #1f3b2d;
      color: #fff;
      padding: 32px 24px;
    }

    .admin-brand {
      color: #fff;
      text-decoration: none;
      font-size: 1.5rem;
      font-weight: 700;
      display: inline-block;
      margin-bottom: 2rem;
    }

    .admin-nav-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 12px;
      color: rgba(255, 255, 255, 0.9);
      text-decoration: none;
      margin-bottom: 10px;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .admin-nav-link:hover,
    .admin-nav-link.active {
      background: rgba(255, 255, 255, 0.12);
      color: #fff;
    }

    .admin-main {
      padding: 28px;
    }

    .admin-topbar {
      background: #fff;
      border-radius: 18px;
      padding: 24px 28px;
      box-shadow: 0 10px 30px rgba(31, 59, 45, 0.08);
      margin-bottom: 24px;
    }

    .admin-card {
      border: 0;
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(31, 59, 45, 0.08);
    }

    .admin-table thead th {
      white-space: nowrap;
      font-size: 0.9rem;
    }

    .admin-table td,
    .admin-table th {
      vertical-align: middle;
    }

    .admin-actions {
      white-space: nowrap;
    }

    @media (max-width: 991px) {
      .admin-shell {
        grid-template-columns: 1fr;
      }

      .admin-sidebar {
        padding: 20px;
      }

      .admin-main {
        padding: 20px;
      }
    }
  </style>
{% endblock %}

{% block body %}
  <div class="admin-shell">
    <aside class="admin-sidebar">
      <a href="{{ path('app_admin_index') }}" class="admin-brand">AgriFlow Admin</a>

      <nav>
        <a href="{{ path('app_admin_index') }}" class="admin-nav-link {{ app.request.attributes.get('_route') == 'app_admin_index' ? 'active' : '' }}">
          <i class="bi bi-speedometer2"></i>
          <span>Dashboard</span>
        </a>
        <a href="{{ path('app_admin_parcelle_index') }}" class="admin-nav-link {{ app.request.attributes.get('_route') starts with 'app_admin_parcelle_' ? 'active' : '' }}">
          <i class="bi bi-grid"></i>
          <span>Parcelles</span>
        </a>
        <a href="{{ path('app_admin_culture_index') }}" class="admin-nav-link {{ app.request.attributes.get('_route') starts with 'app_admin_culture_' ? 'active' : '' }}">
          <i class="bi bi-flower1"></i>
          <span>Cultures</span>
        </a>
      </nav>
    </aside>

    <main class="admin-main">
      <div class="admin-topbar d-flex justify-content-between align-items-start gap-3 flex-wrap">
        <div>
          <h1 class="h3 mb-2">{% block admin_page_title %}Admin{% endblock %}</h1>
          <p class="text-muted mb-0">{% block admin_page_subtitle %}Back office AgriFlow{% endblock %}</p>
        </div>
        {% block admin_page_actions %}{% endblock %}
      </div>

      {% include 'parcelle_culture/_flash_messages.html.twig' %}

      {% block admin_body %}{% endblock %}
    </main>
  </div>
{% endblock %}

{% block javascripts %}
  <script src="{{ asset('template/assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
{% endblock %}
