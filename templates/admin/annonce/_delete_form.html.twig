<form method="post" action="{{ path('app_admin_annonce_delete', {id: annonce.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette annonce ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete-annonce-' ~ annonce.id) }}">
    <button class="btn btn-sm btn-outline-danger">Supprimer</button>
</form>
