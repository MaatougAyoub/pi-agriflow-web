{% extends 'layouts/admin.html.twig' %}

{% block admin_title %}Gestion des annonces{% endblock %}
{% block admin_subtitle %}Liste des annonces publiees sur la plateforme{% endblock %}

{% block admin_body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div></div>
        <a href="{{ path('app_admin_annonce_new') }}" class="btn btn-success">Ajouter une annonce</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Titre</th>
                            <th>Type</th>
                            <th>Statut</th>
                            <th>Prix</th>
                            <th>Stock</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for annonce in annonces %}
                            <tr>
                                <td>
                                    <div class="fw-semibold">{{ annonce.titre }}</div>
                                    <div class="small text-muted">{{ annonce.localisationNormalisee ?: annonce.localisation }}</div>
                                </td>
                                <td>{{ annonce.type.label() }}</td>
                                <td>{{ annonce.statut.label() }}</td>
                                <td>{{ annonce.prix }} TND</td>
                                <td>{{ annonce.quantiteDisponible }}</td>
                                <td class="text-end">
                                    <a href="{{ path('app_marketplace_show', {id: annonce.id}) }}" class="btn btn-sm btn-outline-secondary">Voir</a>
                                    <a href="{{ path('app_admin_annonce_edit', {id: annonce.id}) }}" class="btn btn-sm btn-outline-success">Modifier</a>
                                    {{ include('admin/annonce/_delete_form.html.twig', {annonce: annonce}) }}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Aucune annonce pour le moment.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="agf-pagination mt-4">
        {{ knp_pagination_render(annonces) }}
    </div>
{% endblock %}
