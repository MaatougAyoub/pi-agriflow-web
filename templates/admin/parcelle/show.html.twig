{% extends 'admin/layout.html.twig' %}

{% block admin_title %}Detail parcelle admin{% endblock %}
{% block admin_page_title %}Parcelle #{{ parcelle.id }}{% endblock %}
{% block admin_page_subtitle %}Consultez les informations de cette parcelle et les cultures qui y sont liees.{% endblock %}
{% block admin_page_actions %}
  <a href="{{ path('app_admin_parcelle_index') }}" class="btn btn-outline-secondary">Retour a la liste</a>
{% endblock %}

{% block admin_body %}
  <div class="row g-4">
    <div class="col-lg-7">
      <div class="card admin-card h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between gap-3 flex-wrap mb-4">
            <div>
              <h2 class="h4 mb-1">{{ parcelle.nom ?: 'Parcelle sans nom' }}</h2>
              <p class="text-muted mb-0">{{ parcelle.localisation ?: 'Localisation non renseignee' }}</p>
            </div>
            {% include 'admin/parcelle/_delete_form.html.twig' with {parcelle: parcelle} %}
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <div class="border rounded p-3 h-100">
                <div class="text-muted small mb-1">ID</div>
                <div class="fw-semibold">{{ parcelle.id }}</div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="border rounded p-3 h-100">
                <div class="text-muted small mb-1">Agriculteur ID</div>
                <div class="fw-semibold">{{ parcelle.agriculteurId ?: '-' }}</div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="border rounded p-3 h-100">
                <div class="text-muted small mb-1">Superficie totale</div>
                <div class="fw-semibold">{{ parcelle.superficie|default(0)|number_format(0, '.', ' ') }} m&sup2;</div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="border rounded p-3 h-100">
                <div class="text-muted small mb-1">Superficie disponible</div>
                <div class="fw-semibold">{{ available_surface|number_format(0, '.', ' ') }} m&sup2;</div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="border rounded p-3 h-100">
                <div class="text-muted small mb-1">Type de terre</div>
                <div class="fw-semibold">{{ parcelle.typeTerre ?: 'Non renseigne' }}</div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="border rounded p-3 h-100">
                <div class="text-muted small mb-1">Date de creation</div>
                <div class="fw-semibold">{{ parcelle.dateCreation ? parcelle.dateCreation|date('d/m/Y H:i') : 'Non renseignee' }}</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card admin-card h-100">
        <div class="card-body p-4">
          <h2 class="h4 mb-3">Cultures liees</h2>
          {% if cultures is empty %}
            <p class="text-muted mb-0">Aucune culture liee a cette parcelle.</p>
          {% else %}
            <div class="list-group list-group-flush">
              {% for culture in cultures %}
                <div class="list-group-item px-0">
                  <div class="d-flex justify-content-between align-items-start gap-3">
                    <div>
                      <div class="fw-semibold">{{ culture.nom ?: 'Culture #' ~ culture.id }}</div>
                      <div class="small text-muted">
                        {{ culture.typeCulture ?: 'Type non renseigne' }} ·
                        {{ culture.superficie|default(0)|number_format(0, '.', ' ') }} m&sup2;
                      </div>
                    </div>
                    <a href="{{ path('app_admin_culture_show', {id: culture.id}) }}" class="btn btn-outline-secondary btn-sm">Voir</a>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
{% endblock %}
