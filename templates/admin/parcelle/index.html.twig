{% extends 'admin/layout.html.twig' %}

{% block admin_title %}Admin parcelles{% endblock %}
{% block admin_page_title %}Parcelles{% endblock %}
{% block admin_page_subtitle %}Consultez toutes les parcelles et moderez leur contenu depuis le back office.{% endblock %}

{% block admin_body %}
  <div class="card admin-card mb-4">
    <div class="card-body p-4">
      <form method="get">
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <label for="search" class="form-label">Recherche par nom</label>
            <input type="text" id="search" name="search" class="form-control" value="{{ filters.search }}" placeholder="Nom de parcelle">
          </div>
          <div class="col-md-3">
            <label for="type_terre" class="form-label">Type de terre</label>
            <select id="type_terre" name="type_terre" class="form-select">
              <option value="">Tous</option>
              {% for typeTerre in type_terre_choices %}
                <option value="{{ typeTerre }}" {{ filters.type_terre == typeTerre ? 'selected' : '' }}>{{ typeTerre }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="col-md-2">
            <label for="sort" class="form-label">Tri</label>
            <select id="sort" name="sort" class="form-select">
              {% for sortKey, sortLabel in sort_choices %}
                <option value="{{ sortKey }}" {{ filters.sort == sortKey ? 'selected' : '' }}>{{ sortLabel }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="col-md-2">
            <label for="direction" class="form-label">Ordre</label>
            <select id="direction" name="direction" class="form-select">
              <option value="asc" {{ filters.direction == 'asc' ? 'selected' : '' }}>Asc</option>
              <option value="desc" {{ filters.direction == 'desc' ? 'selected' : '' }}>Desc</option>
            </select>
          </div>
          <div class="col-md-1 d-grid">
            <button class="btn btn-success">Filtrer</button>
          </div>
        </div>
      </form>

      <div class="d-flex justify-content-end mt-3">
        <a href="{{ path('app_admin_parcelle_index') }}" class="btn btn-outline-secondary btn-sm">Reinitialiser</a>
      </div>
    </div>
  </div>

  <div class="card admin-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table admin-table mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Nom</th>
              <th>Agriculteur ID</th>
              <th>Superficie</th>
              <th>Type de terre</th>
              <th>Localisation</th>
              <th>Date de creation</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for parcelle in parcelles %}
              <tr>
                <td>{{ parcelle.id }}</td>
                <td>{{ parcelle.nom ?: 'Sans nom' }}</td>
                <td>{{ parcelle.agriculteurId ?: '-' }}</td>
                <td>{{ parcelle.superficie|default(0)|number_format(0, '.', ' ') }} m&sup2;</td>
                <td>{{ parcelle.typeTerre ?: '-' }}</td>
                <td>{{ parcelle.localisation ?: '-' }}</td>
                <td>{{ parcelle.dateCreation ? parcelle.dateCreation|date('d/m/Y H:i') : '-' }}</td>
                <td class="admin-actions">
                  <a href="{{ path('app_admin_parcelle_show', {id: parcelle.id}) }}" class="btn btn-outline-secondary btn-sm">Voir</a>
                  {% include 'admin/parcelle/_delete_form.html.twig' with {parcelle: parcelle} %}
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="8" class="text-center py-4 text-muted">Aucune parcelle ne correspond aux criteres actuels.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{% endblock %}
