{% extends 'parcelle_culture/layout.html.twig' %}

{% block page_title %}Confirmer la suppression{% endblock %}

{% block hero_title %}Confirmer la suppression de <br> {{ parcelle.nom ?: 'Parcelle #' ~ parcelle.id }}

{% endblock %}
{% block hero_size %}pc-hero-medium{% endblock %}
{% block hero_subtitle %}{% endblock %}





{% block module_body %}
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <h2 class="h4 mb-3">Cette parcelle contient des cultures liees</h2>
      <p class="mb-3">
        Si vous confirmez, la parcelle sera supprimee ainsi que les {{ cultures|length }} culture(s) associee(s).
        Cette action est irreversible.
      </p>

      <div class="mb-4">
        <h3 class="h6">Cultures qui seront supprimees</h3>
        <ul class="mb-0">
          {% for culture in cultures %}
            <li>{{ culture.nom ?: 'Culture #' ~ culture.id }}{% if culture.typeCulture %} - {{ culture.typeCulture }}{% endif %}</li>
          {% endfor %}
        </ul>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <form method="post" action="{{ path('app_parcelle_delete', {id: parcelle.id}) }}">
          <input type="hidden" name="_token" value="{{ csrf_token('delete_parcelle_' ~ parcelle.id) }}">
          <input type="hidden" name="confirm_cascade_delete" value="1">
          <button class="btn btn-danger">Confirmer la suppression</button>
        </form>
        <a href="{{ path('app_parcelle_show', {id: parcelle.id}) }}" class="btn btn-outline-secondary">Annuler</a>
      </div>
    </div>
  </div>
{% endblock %}
