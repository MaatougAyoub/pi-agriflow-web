{% extends 'layouts/front.html.twig' %}

{% block page_title %}Mes reservations - AgriFlow{% endblock %}

{% block front_body %}
    <section class="section pt-5">
        <div class="container">
            <div class="row g-4 align-items-end mb-4">
                <div class="col-lg-8">
                    <h1 class="mb-2">Mes reservations</h1>
                    <p class="text-muted mb-0">Retrouvez les demandes que vous avez envoyees depuis le marketplace.</p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <div class="d-flex gap-2 justify-content-lg-end flex-wrap">
                        <a href="{{ path('app_seller_annonce_index') }}" class="btn btn-success">Mon espace vendeur</a>
                        <a href="{{ path('app_marketplace_index') }}" class="btn btn-outline-success">Retour au marketplace</a>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Annonce</th>
                                    <th>Periode</th>
                                    <th>Quantite</th>
                                    <th>Total</th>
                                    <th>Statut</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for reservation in reservations %}
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">{{ reservation.annonce.titre }}</div>
                                            <div class="small text-muted">{{ reservation.annonce.localisationNormalisee ?: reservation.annonce.localisation }}</div>
                                        </td>
                                        <td>
                                            {% if reservation.annonce.isLocation() %}
                                                {{ reservation.dateDebut|date('d/m/Y') }} - {{ reservation.dateFin|date('d/m/Y') }}
                                            {% else %}
                                                Vente ponctuelle
                                            {% endif %}
                                        </td>
                                        <td>{{ reservation.quantite }}</td>
                                        <td>{{ reservation.prixTotal }} TND</td>
                                        <td>{{ reservation.statut.label() }}</td>
                                        <td class="text-end">
                                            <a href="{{ path('app_reservation_quote', {id: reservation.id}) }}" class="btn btn-sm btn-outline-secondary">Devis PDF</a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">Aucune reservation enregistree pour le moment.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="agf-pagination mt-4">
                {{ knp_pagination_render(reservations) }}
            </div>
        </div>
    </section>
{% endblock %}
